## P.5 — Función pública `proyectarISPB`

Pegar después del bloque P.4. **Esta es la función principal.**

Estructura de retorno alineada al pie de la letra con la Sección 14.6 del Códyce.

```js
  // ━━━ INICIO P.5 — Función pública proyectarISPB v16.7.0 ━━━

  /**
   * Proyecta la evolución del ISPB en el tiempo bajo desgasificación
   * natural, evaporación y eventos programados. Integración Euler
   * con paso de 1 h. Sección 14 del Códyce.
   *
   * @param {object} estadoInicial - {pH, ALK, CH, CYA, TDS, FC,
   *   temperatura, recubrimiento, profundidad, regimen_aireacion,
   *   evaporacion_mm_dia, volumen_m3, modo_operativo}
   * @param {number} horizonte_h - horas a proyectar (1..168)
   * @param {Array}  eventos - [{hora, tipo, ...payload}]
   * @param {object} opciones - {forzar:bool}
   * @returns {object} estructura doctrinal Sección 14.6
   */
  proyectarISPB(estadoInicial, horizonte_h, eventos, opciones) {
    const opts = opciones || {};

    // ───── 1. VALIDACIÓN DE INPUTS ─────
    if (!estadoInicial || typeof estadoInicial !== 'object') {
      return { error: true, mensaje: 'estadoInicial requerido (objeto).' };
    }
    const requeridos = ['pH', 'ALK', 'CH', 'temperatura', 'volumen_m3'];
    for (const k of requeridos) {
      if (estadoInicial[k] === undefined || estadoInicial[k] === null) {
        return { error: true, mensaje: 'Campo requerido faltante: ' + k };
      }
    }

    let H = parseInt(horizonte_h, 10);
    if (isNaN(H) || H < 1) H = 24;
    if (H > this.CONST.PROYECTOR_HORIZONTE_MAX) {
      H = this.CONST.PROYECTOR_HORIZONTE_MAX;
    }

    // ───── 2. MODO OPERATIVO PROHIBIDO ─────
    // Sección 14.8.3 del Códyce.
    const modo = String(estadoInicial.modo_operativo || 'rutinario').toLowerCase();
    if (this.CONST.PROYECTOR_MODOS_PROHIBIDOS.indexOf(modo) !== -1 && !opts.forzar) {
      return {
        error: true,
        bloqueado: true,
        mensaje: 'Proyección bloqueada: modo "' + modo + '" no admite proyección ' +
                 '(usar opciones.forzar=true bajo responsabilidad del técnico).'
      };
    }

    // ───── 3. RÉGIMEN DE AIREACIÓN ─────
    const regimen = String(estadoInicial.regimen_aireacion || 'filtracion').toLowerCase();
    const velBase = this.CONST.DESGASIFICACION_VEL_BASE[regimen];
    if (velBase === undefined) {
      return { error: true, mensaje: 'regimen_aireacion no reconocido: ' + regimen };
    }

    // ───── 4. ZONA DE RECUBRIMIENTO ─────
    const zona = this._zonaSeguridadRecubrimiento(estadoInicial.recubrimiento);

    // ───── 5. ADVERTENCIAS NO BLOQUEANTES ─────
    const advertencias = [];
    if ((estadoInicial.CYA || 0) > 75) {
      advertencias.push('CYA elevado (' + estadoInicial.CYA +
        ' ppm): Sección 14.8.3(d) recomienda retrolavado/dilución previa.');
    }

    // ───── 6. ESTADO DE TRABAJO ─────
    const estado = {
      pH:          parseFloat(estadoInicial.pH),
      ALK:         parseFloat(estadoInicial.ALK),
      CH:          parseFloat(estadoInicial.CH),
      CYA:         parseFloat(estadoInicial.CYA || 0),
      TDS:         parseFloat(estadoInicial.TDS || 0),
      FC:          parseFloat(estadoInicial.FC  || 0),
      temperatura: parseFloat(estadoInicial.temperatura),
      profundidad: parseFloat(estadoInicial.profundidad || 1.5)
    };
    const V_m3      = parseFloat(estadoInicial.volumen_m3);
    const evapMmDia = parseFloat(estadoInicial.evaporacion_mm_dia ||
                                 this.CONST.EVAPORACION_MM_DIA_DEFAULT);

    // F_T constante en el horizonte (Sección 14.4: justificación doctrinal)
    const F_T = this._factorTemp(estado.temperatura);

    // ───── 7. INDEXAR EVENTOS POR HORA ─────
    const eventosPorHora = {};
    if (Array.isArray(eventos)) {
      for (const ev of eventos) {
        const h = parseInt(ev.hora, 10);
        if (!isNaN(h) && h >= 0 && h <= H) {
          if (!eventosPorHora[h]) eventosPorHora[h] = [];
          eventosPorHora[h].push(ev);
        }
      }
    }

    // ───── 8. PUNTO INICIAL ─────
    this._recalcularPHsProyector(estado, F_T);
    const ispb_inicial = estado.ispb;
    const en_zona_ini  = (ispb_inicial >= zona.min && ispb_inicial <= zona.max);

    const curva = [];
    curva.push({
      h:                0,
      pH:               parseFloat(estado.pH.toFixed(3)),
      T_agua:           estado.temperatura,
      ALK:              parseFloat(estado.ALK.toFixed(1)),
      ALK_corr:         estado.alkCorr,
      CH:               parseFloat(estado.CH.toFixed(1)),
      CYA:              parseFloat(estado.CYA.toFixed(1)),
      TDS:              parseFloat((estado.TDS || 0).toFixed(0)),
      pHs:              estado.pHs,
      ISPB:             estado.ispb,
      en_zona:          en_zona_ini,
      factor_wojtowicz: estado.wojtowicz_factor
    });

    // ───── 9. INTEGRACIÓN EULER ─────
    let alerta_salida = null;
    const racha_fuera = [];

    for (let h = 1; h <= H; h++) {
      // 9.1 Desgasificación con techo suavizado
      const techo = this._techoSuavizadoDesgasificacion(estado.pH);
      estado.pH = estado.pH + velBase * techo;

      // 9.2 Evaporación (concentra iones)
      const fEvap = this._evaporacionFactorHora(estado.profundidad, evapMmDia);
      estado.ALK = estado.ALK * fEvap;
      estado.CH  = estado.CH  * fEvap;
      estado.CYA = estado.CYA * fEvap;
      estado.TDS = (estado.TDS || 0) * fEvap;

      // 9.3 Eventos programados a esta hora
      if (eventosPorHora[h]) {
        for (const ev of eventosPorHora[h]) {
          this._aplicarEventoProyector(estado, ev, V_m3);
        }
      }

      // 9.4 Clamp físico
      if (this.CONST.PH_FISICO_MIN !== undefined) {
        if (estado.pH < this.CONST.PH_FISICO_MIN) estado.pH = this.CONST.PH_FISICO_MIN;
        if (estado.pH > this.CONST.PH_FISICO_MAX) estado.pH = this.CONST.PH_FISICO_MAX;
      } else {
        if (estado.pH < 4) estado.pH = 4;
        if (estado.pH > 11) estado.pH = 11;
      }
      if (estado.ALK < 1) estado.ALK = 1;
      if (estado.CH  < 1) estado.CH  = 1;
      if (estado.CYA < 0) estado.CYA = 0;
      if (estado.FC  < 0) estado.FC  = 0;

      // 9.5 Recalcular pHs / ISPB
      this._recalcularPHsProyector(estado, F_T);

      // 9.6 Detección de cruce con confirmación de 3 puntos
      // Sección 14.2.3 del Códyce.
      const fueraIncr = estado.ispb > zona.max;
      const fueraCorr = estado.ispb < zona.min;
      const en_zona   = !(fueraIncr || fueraCorr);

      if (!en_zona) {
        racha_fuera.push({
          hora:      h,
          ispb:      estado.ispb,
          direccion: fueraIncr ? 'incrustante' : 'corrosivo',
          umbral:    fueraIncr ? zona.max : zona.min
        });
        if (racha_fuera.length >= this.CONST.PROYECTOR_PUNTOS_CRUCE_CONFIRMACION &&
            !alerta_salida) {
          // Primer punto de la racha = inicio oficial del cruce
          const inicio = racha_fuera[racha_fuera.length -
                                     this.CONST.PROYECTOR_PUNTOS_CRUCE_CONFIRMACION];
          alerta_salida = {
            hora:           inicio.hora,
            direccion:      inicio.direccion,
            ISPB_en_cruce:  parseFloat(inicio.ispb.toFixed(3)),
            magnitud_cruce: parseFloat(Math.abs(inicio.ispb - inicio.umbral).toFixed(3)),
            umbral_violado: inicio.umbral
          };
        }
      } else {
        racha_fuera.length = 0; // se rompió la racha
      }

      // 9.7 Añadir punto a la curva
      curva.push({
        h:                h,
        pH:               parseFloat(estado.pH.toFixed(3)),
        T_agua:           estado.temperatura,
        ALK:              parseFloat(estado.ALK.toFixed(1)),
        ALK_corr:         estado.alkCorr,
        CH:               parseFloat(estado.CH.toFixed(1)),
        CYA:              parseFloat(estado.CYA.toFixed(1)),
        TDS:              parseFloat((estado.TDS || 0).toFixed(0)),
        pHs:              estado.pHs,
        ISPB:             estado.ispb,
        en_zona:          en_zona,
        factor_wojtowicz: estado.wojtowicz_factor
      });
    }

    // ───── 10. RESUMEN A HORAS CLAVE ─────
    // Sección 14.6 del Códyce.
    const horasResumen = [0, 24, 48, 72].filter(h => h <= H);
    const resumen = {};
    horasResumen.forEach((h) => {
      if (curva[h]) {
        resumen['h' + (h === 0 ? '0' : h)] = {
          ISPB:    curva[h].ISPB,
          en_zona: curva[h].en_zona
        };
      }
    });
    // Renombrar h0 -> t0 por convención doctrinal
    if (resumen.h0) { resumen.t0 = resumen.h0; delete resumen.h0; }

    // ───── 11. RECOMENDACIÓN ─────
    const recomendacion = this._proyectorRecomendacion(
      alerta_salida, zona, H, regimen
    );

    // ───── 12. RETORNO ESTRUCTURADO (Sección 14.6) ─────
    return {
      version:           '16.7.0',
      estadoInicial: {
        pH:            estadoInicial.pH,
        ISPB:          ispb_inicial,
        recubrimiento: zona.recubrimiento
      },
      horizonte_h:        H,
      regimen_aireacion:  regimen,
      curva:              curva,
      resumen:            resumen,
      alerta_salida:      alerta_salida,
      recomendacion:      recomendacion,
      zona_recubrimiento: { min: zona.min, max: zona.max },
      advertencias:       advertencias,
      integracion_F:      (typeof this.calcDeltaPhPorDosificacion === 'function'),
      firma:              this.CONST.FIRMA
    };
  },

  // ━━━ FIN P.5 ━━━
