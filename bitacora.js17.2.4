  /**
   * V16.7.0 ADD — Construye el contexto del gemelo (lecturas actuales)
   * para alimentar a Chemistry.calcDeltaPorAplicacion.
   * @returns {Object}
   * @private
   */
  function _construirContextoGemeloVivo() {
    const pzq = (_gemeloActivo && _gemeloActivo.punto_cero_quimico) || {};
    const geo = (_gemeloActivo && _gemeloActivo.geometria_adn) || {};
    const recubrimientoCtx = (geo.recubrimiento && geo.recubrimiento.tipo)
      ? String(geo.recubrimiento.tipo).toLowerCase()
      : 'porcelanato';

    return {
      ph:            _numVal('bit-ph', 0)          || pzq.ph                || 7.4,
      alcalinidad:   _numVal('bit-alcalinidad', 0) || pzq.alcalinidad       || 100,
      temperatura:   _numVal('bit-temperatura', 0) || pzq.temperatura_llenado || 28,
      dureza:        _numVal('bit-dureza', 0)      || pzq.dureza            || 250,
      cianurico:     _numVal('bit-cianurico', 0)   || pzq.cianurico         || 30,
      tds:           _numVal('bit-tds', 0)         || 0,
      recubrimiento: recubrimientoCtx
    };
  }

  // V17.2.4 ADD FIX DELTA-PH-RESCATE
  /**
   * Decide si una dosificación de ácido o cloro ácido debe usar el
   * solver termodinámico del Entregable F en lugar de la heurística CPO.
   * @param {string} claveProducto
   * @param {string} modoOperativo
   * @param {number} alkActual - alcalinidad en ppm
   * @returns {boolean}
   * @private
   */
  function _debeUsarEntregableF(claveProducto, modoOperativo, alkActual) {
    const productosAplicables = new Set([
      'acido-muriatico', 'acido',
      'tricloro-polvo', 'tricloro-tab3', 'tricloro-tab1',
      'ph-menos'
    ]);
    if (!productosAplicables.has(claveProducto)) return false;

    if (modoOperativo === 'rescate' ||
        modoOperativo === 'recuperacion_severa' ||
        modoOperativo === 'post_choque') return true;

    if (typeof alkActual === 'number' && !isNaN(alkActual) && alkActual < 80) {
      return true;
    }
    return false;
  }

  /**
   * Convierte cantidad+unidad a gramos de producto comercial para
   * alimentar a Chemistry.calcDeltaPhPorDosificacion.
   * Densidad HCl 31 %: 1.16 g/mL.
   * @param {string} clave
   * @param {number} cantidad
   * @param {string} unidad - 'g', 'ml', 'l', 'kg', 'tabs'
   * @returns {number} gramos
   * @private
   */
  function _convertirAGramos(clave, cantidad, unidad) {
    const u = (unidad || '').toLowerCase();
    if (clave === 'acido-muriatico' || clave === 'acido') {
      if (u === 'ml') return cantidad * 1.16;
      if (u === 'l')  return cantidad * 1160;
      return cantidad;
    }
    if (clave === 'tricloro-tab3') return cantidad * 200;
    if (clave === 'tricloro-tab1') return cantidad * 20;
    if (u === 'kg') return cantidad * 1000;
    if (u === 'l')  return cantidad * 1000;
    return cantidad;
  }

  /**
   * Wrapper que decide qué motor usar y devuelve el objeto de deltas
   * en el mismo formato que Chemistry.calcDeltaPorAplicacion.
   * @returns {Object|null}
   * @private
   */
  function _calcularDeltasInteligente(clave, cantidad, unidad, volM3, ctx, modoOperativo) {
    const alkActual = ctx && typeof ctx.alcalinidad === 'number' ? ctx.alcalinidad : null;

    if (_debeUsarEntregableF(clave, modoOperativo, alkActual) &&
        window.Chemistry &&
        typeof window.Chemistry.calcDeltaPhPorDosificacion === 'function') {

      try {
        const gramos = _convertirAGramos(clave, cantidad, unidad);
        const resF = window.Chemistry.calcDeltaPhPorDosificacion(
          clave, gramos, volM3, ctx
        );

        if (!resF || !resF.base) {
          console.warn('[Bitácora V17.2.4] Entregable F no devolvió escenario base, fallback a heurística.');
        } else {
          const base = resF.base;
          // Complementar con deltas de Cl/CYA/CH desde la heurística original
          let resHeur = null;
          try {
            resHeur = window.Chemistry.calcDeltaPorAplicacion(clave, cantidad, unidad, volM3, ctx);
          } catch (e) { /* ignorar */ }

          return {
            deltaPH:  base.deltaPH  != null ? base.deltaPH  : (resHeur ? resHeur.deltaPH  : 0),
            deltaALK: base.deltaALK != null ? base.deltaALK : (resHeur ? resHeur.deltaALK : 0),
            deltaCl:  resHeur && resHeur.deltaCl  != null ? resHeur.deltaCl  : 0,
            deltaCYA: resHeur && resHeur.deltaCYA != null ? resHeur.deltaCYA : 0,
            deltaCH:  resHeur && resHeur.deltaCH  != null ? resHeur.deltaCH  : 0,
            _motor_usado: 'entregable_f',
            _escenarios: resF
          };
        }
      } catch (e) {
        console.warn('[Bitácora V17.2.4] Error en Entregable F, fallback a heurística:', e);
      }
    }

    // Fallback: heurística CPO original
    if (window.Chemistry && typeof window.Chemistry.calcDeltaPorAplicacion === 'function') {
      const r = window.Chemistry.calcDeltaPorAplicacion(clave, cantidad, unidad, volM3, ctx);
      if (r) r._motor_usado = 'heuristica_cpo';
      return r;
    }
    return null;
  }
  // V17.2.4 END FIX DELTA-PH-RESCATE
   * contra los umbrales proporcionados.
   * @param {Object} deltas
   * @param {Object} umbrales
   * @returns {{ nivel: 'ok'|'warn'|'block', detalles: Array }}
   * @private
   */
  function _evaluarSeveridad(deltas, umbrales) {
    if (!umbrales) { return { nivel: 'ok', detalles: [] }; }
    let nivelGlobal = 'ok';
    const detalles = [];

    const mapping = {
      deltaPH:  umbrales.deltaPh,
      deltaALK: umbrales.deltaAlk,
      deltaCl:  umbrales.deltaCl,
      deltaCYA: umbrales.deltaCya,
      deltaCH:  umbrales.deltaCh
    };

    Object.keys(mapping).forEach((k) => {
      const v = deltas[k];
      if (v == null || isNaN(v)) return;
      const abs = Math.abs(v);
      const u = mapping[k];
      let nivel = 'ok';
      if (abs > u.block) nivel = 'block';
      else if (abs > u.warn) nivel = 'warn';

      detalles.push({ key: k, valor: v, nivel });

      if (nivel === 'block') nivelGlobal = 'block';
      else if (nivel === 'warn' && nivelGlobal !== 'block') nivelGlobal = 'warn';
    });

    return { nivel: nivelGlobal, detalles };
  }

  /**
   * V16.7.0 ADD — Renderiza el preview de impacto dentro de la fila.
   * V17.2.2 FIX BUG-002: lee poolState real de DB.
   * @param {HTMLElement} fila
   * @param {Object|null} resultado
   * @param {string} [mensajeInfo]
   * @private
   */
  function _renderPreviewImpacto(fila, resultado, mensajeInfo) {
    if (!fila) return;

    let preview = fila.querySelector('.dosis-impacto');
    if (!preview) {
      preview = document.createElement('div');
      preview.className = 'dosis-impacto';
      preview.style.cssText =
        'flex-basis:100%;width:100%;margin-top:6px;padding:8px 10px;border-radius:6px;' +
        'font-size:0.78rem;line-height:1.4;background:rgba(59,130,246,0.08);' +
        'color:#1e3a8a;border:1px solid rgba(59,130,246,0.25);';
      fila.appendChild(preview);
    }

    // V17.2.2 FIX BUG-002: leer poolState real de DB en lugar de hardcodear 'rutinario'
    let umbralesDinamicos = null;
    if (resultado) {
      let poolStateReal = null;
      try {
        if (window.DB && typeof DB.getPoolState === 'function') {
          poolStateReal = DB.getPoolState(_albercaActivaId);
        }
      } catch (e) {
        console.warn('[Bitacora._renderPreviewImpacto] No se pudo leer poolState:', e);
      }

      const ctx = _construirContextoGemeloVivo();
      const effectivePoolState = poolStateReal || {
        calculado: {
          cianurico: ctx.cianurico,
          modo_operativo: 'rutinario'
        }
      };
      umbralesDinamicos = _getUmbralesDosisActuales(effectivePoolState);
    }

    if (!resultado) {
      preview.style.background = 'rgba(0,0,0,0.04)';
      preview.style.color = '#555';
      preview.style.border = '1px dashed rgba(0,0,0,0.15)';
      preview.innerHTML = `<em>${mensajeInfo || 'Ingresa producto y cantidad para ver el impacto químico estimado.'}</em>`;
      fila.classList.remove('dosis-bloqueada');
      _actualizarEstadoGuardado();
      return;
    }

    const partes = [];
    Object.keys(ETIQUETAS_DELTA).forEach((k) => {
      const v = resultado[k];
      if (v == null || isNaN(v) || Math.abs(v) < 0.001) return;
      const meta = ETIQUETAS_DELTA[k];
      const signo = v > 0 ? '+' : '';
      const dec = (k === 'deltaPH') ? 2 : 1;
      partes.push(`<strong>${meta.label}</strong> ${signo}${v.toFixed(dec)}${meta.unidad}`);
    });

    const sev = _evaluarSeveridad(resultado, umbralesDinamicos);

    if (sev.nivel === 'block') {
      preview.style.background = '#fee2e2';
      preview.style.color = '#7f1d1d';
      preview.style.border = '1px solid #ef4444';
      fila.classList.add('dosis-bloqueada');
    } else if (sev.nivel === 'warn') {
      preview.style.background = '#fef3c7';
      preview.style.color = '#78350f';
      preview.style.border = '1px solid #f59e0b';
      fila.classList.remove('dosis-bloqueada');
    } else {
      preview.style.background = 'rgba(45,164,78,0.10)';
      preview.style.color = '#14532d';
      preview.style.border = '1px solid rgba(45,164,78,0.35)';
      fila.classList.remove('dosis-bloqueada');
    }

    let header = '';
    if (sev.nivel === 'block') {
      header = '🚫 <strong>Dosis fuera de rango seguro.</strong> Reduce la cantidad antes de guardar.';
    } else if (sev.nivel === 'warn') {
      header = '⚠️ <strong>Dosis alta.</strong> Verifica que sea correcta.';
    } else {
      header = '✅ Impacto químico estimado:';
    }

    preview.innerHTML = `
      <div style="margin-bottom:4px">${header}</div>
      <div style="display:flex;flex-wrap:wrap;gap:8px 14px">
        ${partes.length > 0 ? partes.join(' · ') : '<em>Sin impacto significativo</em>'}
      </div>
    `;

    _actualizarEstadoGuardado();
  }

  /**
   * V16.7.0 ADD — Calcula el preview de impacto para una fila concreta.
   * V16.7.0 GEMINI-MOD — Inyecta modo_acido al contexto si aplica.
   * @param {HTMLElement} fila
   * @private
   */
  function _calcularImpactoFila(fila) {
    if (!fila) return;

    const selProd  = fila.querySelector('.dosis-producto');
    const inputCant = fila.querySelector('.dosis-cantidad');
    const spanUnid  = fila.querySelector('.dosis-unidad');

    if (!selProd || !inputCant) return;

    const clave = selProd.value;
    const cantidad = parseFloat(inputCant.value);
    const unidad = (spanUnid?.textContent || '').toLowerCase();

    if (!_albercaActivaId || !_gemeloActivo) {
      _renderPreviewImpacto(fila, null, 'Selecciona una alberca para ver el impacto químico.');
      return;
    }
    if (!clave) {
      _renderPreviewImpacto(fila, null, 'Selecciona un producto.');
      return;
    }
    if (!cantidad || cantidad <= 0) {
      _renderPreviewImpacto(fila, null, 'Ingresa la cantidad para estimar el impacto.');
      return;
    }
    if (!window.Chemistry || typeof window.Chemistry.calcDeltaPorAplicacion !== 'function') {
      _renderPreviewImpacto(fila, null, 'Chemistry.calcDeltaPorAplicacion no disponible (requiere V16.4.2+).');
      return;
    }

    const volM3 = parseFloat(_gemeloActivo.geometria_adn?.volumen_m3) || 0;
    if (volM3 <= 0) {
      _renderPreviewImpacto(fila, null, 'Volumen de la alberca no definido en el expediente.');
      return;
    }

    const ctx = _construirContextoGemeloVivo();

    // V16.7.0 GEMINI-MOD — Inyección de modo_acido
    if (clave === 'acido-muriatico' || clave === 'acido') {
      const radio = fila.querySelector(`input[name="modo_acido_${fila.id}"]:checked`);
      if (radio) ctx.modo_acido = radio.value;
    }

    try {
      // V17.2.4 MOD FIX DELTA-PH-RESCATE: detectar modo y usar Entregable F si aplica
      let modoOp = 'rutinario';
      try {
        if (window.DB && typeof DB.getPoolState === 'function' && _albercaActivaId) {
          const ps = DB.getPoolState(_albercaActivaId);
          if (ps && ps.calculado && ps.calculado.modo_operativo) {
            modoOp = ps.calculado.modo_operativo;
          }
        }
      } catch (e) { /* silenciar */ }

      const res = _calcularDeltasInteligente(clave, cantidad, unidad, volM3, ctx, modoOp);
      if (!res) {
        _renderPreviewImpacto(fila, null, 'No se pudo calcular el impacto para este producto.');
        return;
      }
      _renderPreviewImpacto(fila, res);
      // V17.2.4 END MOD
    } catch (e) {
      console.warn('[Bitácora] Error en preview de impacto:', e);
      _renderPreviewImpacto(fila, null, 'Error al calcular el impacto: ' + e.message);
    }
  }

  /**
   * V16.7.0 ADD — Programa el cálculo del preview con debounce de 250 ms.
   * @param {HTMLElement} fila
   * @private
   */
  function _programarPreviewFila(fila) {
    if (!fila || !fila.id) return;

    const prev = _previewDebounce.get(fila.id);
    if (prev) clearTimeout(prev);

    const t = setTimeout(() => {
      _previewDebounce.delete(fila.id);
      _calcularImpactoFila(fila);
    }, 250);

    _previewDebounce.set(fila.id, t);
  }

  /**
   * V16.7.0 ADD — Recalcula el preview de TODAS las filas activas.
   * @private
   */
  function _recalcularTodosLosPreviews() {
    const container = $('dosificacion-container');
    if (!container) return;
    const filas = container.querySelectorAll('.dosis-row');
    filas.forEach((fila) => _programarPreviewFila(fila));
  }

  /**
   * V16.7.0 ADD — Actualiza el estado del botón "Guardar bitácora".
   * @private
   */
  function _actualizarEstadoGuardado() {
    const btn = $('btn-guardar-bitacora');
    if (!btn) return;

    const container = $('dosificacion-container');
    const bloqueadas = container ? container.querySelectorAll('.dosis-row.dosis-bloqueada').length : 0;

    if (bloqueadas > 0) {
      btn.disabled = true;
      btn.title = `${bloqueadas} dosis fuera de rango seguro. Ajusta antes de guardar.`;
      btn.style.opacity = '0.55';
      btn.style.cursor = 'not-allowed';
    } else {
      btn.disabled = false;
      btn.title = '';
      btn.style.opacity = '';
      btn.style.cursor = '';
    }
  }

