        if (btnDetener) {
          btnDetener.textContent = 'Detener Llenado';
          btnDetener.style.background = '';
        }
      }, 3000);
      return;
    }

    clearTimeout(_llenadoDetenerTimeout);
    clearInterval(_cronometroLlenadoInterval);
    _cronometroLlenadoActivo = false;
    _llenadoDetenerPrimerClic = false;

    const btnIniciar = $('btn-iniciar-llenado');
    const btnDetener = $('btn-detener-llenado');

    if (btnIniciar) btnIniciar.disabled = false;
    if (btnDetener) {
      btnDetener.disabled = true;
      btnDetener.textContent = 'Detener Llenado';
      btnDetener.style.background = '';
