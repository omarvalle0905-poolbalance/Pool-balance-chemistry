  function _actualizarSubselectoresTipo() {
    const tipo = document.getElementById('bit-tipo')
                 ? document.getElementById('bit-tipo').value : '';
    const cont = document.getElementById('bit-subselectores-tipo');
    const grpAlga = document.getElementById('bit-grp-tipo-alga');
    const grpMetal = document.getElementById('bit-grp-metal-presunto');
    const grpRecub = document.getElementById('bit-grp-recubrimiento-confirmado');

    if (!cont) return;

    if (grpAlga) grpAlga.style.display = (tipo === 'algas') ? 'block' : 'none';
    if (grpMetal) grpMetal.style.display = (tipo === 'recuperacion_metales') ? 'block' : 'none';
    if (grpRecub) grpRecub.style.display = (tipo === 'correccion_sarro') ? 'block' : 'none';

    cont.style.display = (tipo === 'algas' || tipo === 'recuperacion_metales' ||
                          tipo === 'correccion_sarro') ? 'block' : 'none';

    const acordeonSalud = document.getElementById('bit-acordeon-salud');
    if (acordeonSalud && tipo && tipo !== 'rutina') {
      acordeonSalud.open = true;
    }
  }

