  /**
   * V17.2.0 ADD: evaluación de override bidireccional (V17.2 sec 5.1).
   * @private
   */
  function _evaluarOverrideTipoServicio() {
    const tipoServicio = document.getElementById('bit-tipo')
                         ? document.getElementById('bit-tipo').value : '';
    const claridad = document.getElementById('bit-claridad')
                     ? parseInt(document.getElementById('bit-claridad').value, 10) : NaN;
    const naturalezaColor = (document.querySelector('input[name="bit-naturaleza-color"]:checked'))
                            ? document.querySelector('input[name="bit-naturaleza-color"]:checked').value : 'ninguna';
    const tipoAlga = document.getElementById('bit-tipo-alga-presunta')
                     ? document.getElementById('bit-tipo-alga-presunta').value : 'ninguna';

    const banner = document.getElementById('bit-banner-override');
    if (!banner) return;

    let inconsistencia = null;

    if (tipoServicio === 'rutina') {
      if (!isNaN(claridad) && claridad >= 3) {
        inconsistencia = {
          tipo: 'escalacion',
          mensaje: 'Detectaste claridad nivel ' + claridad +
                   ' (' + (NIVELES_CLARIDAD[claridad] ? NIVELES_CLARIDAD[claridad].label : '') + ').' +
                   ' El tipo de servicio actual es Mantenimiento de Rutina.',
          accion_principal: 'algas',
          texto_accion: 'Cambiar a Tratamiento por Algas'
        };
      } else if (tipoAlga !== 'ninguna' && tipoAlga !== 'muriendo') {
        inconsistencia = {
          tipo: 'escalacion',
          mensaje: 'Detectaste alga ' + tipoAlga + '. El tipo de servicio actual es Mantenimiento de Rutina.',
          accion_principal: 'algas',
          texto_accion: 'Cambiar a Tratamiento por Algas'
        };
      } else if (naturalezaColor === 'metales') {
        inconsistencia = {
          tipo: 'escalacion',
          mensaje: 'Detectaste naturaleza del color = METALES. El tipo de servicio actual es Mantenimiento de Rutina.',
          accion_principal: 'recuperacion_metales',
          texto_accion: 'Cambiar a Tratamiento de Metales'
        };
      }
    }

    if (tipoServicio === 'algas' && !isNaN(claridad) && claridad === 0 &&
        (tipoAlga === 'ninguna' || tipoAlga === 'muriendo') &&
        naturalezaColor === 'ninguna') {
      inconsistencia = {
        tipo: 'descalacion',
        mensaje: 'Tipo de servicio = Tratamiento por Algas, pero el agua está cristalina sin algas visibles.',
        accion_principal: 'rutina',
        texto_accion: 'Cambiar a Mantenimiento Rutinario'
      };
    }

    if (!inconsistencia) {
      banner.style.display = 'none';
      banner.innerHTML = '';
      return;
    }

    banner.style.display = 'block';
    banner.innerHTML =
      '<div style="background:#fef3c7; border:2px solid #f59e0b;' +
      ' border-radius:8px; padding:12px; margin:12px 0; color:#78350f;">' +
        '<strong>⚠️ Inconsistencia detectada</strong><br>' +
        inconsistencia.mensaje + '<br><br>' +
        '<button type="button" id="bit-override-aceptar"' +
        ' style="background:#f59e0b; color:white; padding:8px 14px;' +
        ' border:none; border-radius:6px; font-weight:bold; margin-right:8px; cursor:pointer;">' +
        inconsistencia.texto_accion + '</button>' +
        '<button type="button" id="bit-override-mantener"' +
        ' style="background:white; color:#78350f; padding:8px 14px;' +
        ' border:1px solid #f59e0b; border-radius:6px; cursor:pointer;">' +
        'Mantener mi selección' + '</button>' +
      '</div>';

    document.getElementById('bit-override-aceptar').onclick = function() {
      const sel = document.getElementById('bit-tipo');
      if (sel) sel.value = inconsistencia.accion_principal;
      banner.style.display = 'none';
      banner.innerHTML = '';
      sel.dispatchEvent(new Event('change'));
    };
    document.getElementById('bit-override-mantener').onclick = function() {
      banner.style.display = 'none';
      banner.innerHTML = '';
    };
  }

