  /**
   * Obtiene un elemento del DOM por ID, con manejo de null.
   * @param {string} id - ID del elemento.
   * @returns {HTMLElement|null}
   * @private
   */
  function $(id) {
    return document.getElementById(id);
  }

  /**
   * Obtiene el valor de un input numérico.
   * @param {string} id - ID del input.
   * @param {number} [fallback=0] - Valor por defecto.
   * @returns {number}
   * @private
   */
  function _numVal(id, fallback = 0) {
    const el = $(id);
    if (!el) return fallback;
    const v = parseFloat(el.value);
    return isNaN(v) ? fallback : v;
  }

  /**
   * Obtiene el valor string de un input/select.
   * @param {string} id - ID del elemento.
   * @param {string} [fallback=''] - Valor por defecto.
   * @returns {string}
   * @private
   */
  function _strVal(id, fallback = '') {
    const el = $(id);
    return el ? (el.value || fallback) : fallback;
  }

  /**
   * Obtiene el estado checked de un checkbox.
   * @param {string} id - ID del checkbox.
