  /**
   * Claves de productos considerados "cloro" para el bloqueo en modo metales.
   * V17.2.3 FIX BUG-002.
   * @private
   */
  const _CLAVES_CLORO = new Set([
    'tricloro-polvo', 'tricloro-tab3', 'tricloro-tab1',
    'hipoclorito-calcio',
    'cloro-liquido'
  ]);

  /**
   * Añade una nueva fila de dosificación al contenedor.
   * V16.7.0 MOD: preview en vivo + listeners de debounce.
   * V16.7.0 GEMINI-MOD: selector de modo ácido para ácido muriático.
   * V17.2.3 FIX BUG-002: verifica modo_operativo antes de agregar
   *   productos clorados cuando el modo es 'metales'.
   * @private
   */
  function _agregarFilaDosificacion() {
    // ── V17.2.3 FIX BUG-002: bloqueo preventivo al agregar fila ──
    // (El bloqueo por producto específico se hace en el listener 'change'
    //  del selector de producto; aquí se hace la comprobación inicial
    //  para la fila recién agregada antes de que el usuario elija producto.)
    // La comprobación real por producto se aplica al momento de elegir
    // el producto dentro de la fila — ver selProd.addEventListener('change').

    const container = $('dosificacion-container');
    if (!container) return;

    _dosificacionRowCounter++;
    const rowId = `dosis-row-${_dosificacionRowCounter}`;

    const row = document.createElement('div');
    row.id = rowId;
    row.className = 'dosis-row';
    row.style.cssText =
      'display:flex;flex-wrap:wrap;gap:8px;align-items:center;padding:8px;' +
      'margin-bottom:6px;background:rgba(0,0,0,0.02);border-radius:6px;border:1px solid rgba(0,0,0,0.06);';

    // Select de categoría
    const selCat = document.createElement('select');
    selCat.className = 'dosis-categoria';
    selCat.style.cssText = 'flex:1;min-width:120px;padding:6px;border-radius:4px;border:1px solid #ccc;font-size:0.82rem;';
    selCat.innerHTML = '<option value="">Categoría...</option>';
    CATEGORIAS_PRODUCTO.forEach((cat) => {
      const opt = document.createElement('option');
      opt.value = cat.value;
      opt.textContent = cat.label;
      selCat.appendChild(opt);
    });

    // Select de producto
    const selProd = document.createElement('select');
    selProd.className = 'dosis-producto';
    selProd.style.cssText = 'flex:2;min-width:160px;padding:6px;border-radius:4px;border:1px solid #ccc;font-size:0.82rem;';
    selProd.innerHTML = '<option value="">Producto...</option>';
    selProd.disabled = true;

    // Input de cantidad
    const inputCant = document.createElement('input');
    inputCant.type = 'number';
    inputCant.className = 'dosis-cantidad';
    inputCant.placeholder = 'Cant.';
    inputCant.min = '0';
    inputCant.step = 'any';
    inputCant.style.cssText = 'width:70px;padding:6px;border-radius:4px;border:1px solid #ccc;font-size:0.82rem;text-align:right;';

    // Span de unidad
    const spanUnidad = document.createElement('span');
    spanUnidad.className = 'dosis-unidad';
    spanUnidad.style.cssText = 'font-size:0.78rem;color:#666;min-width:24px;';
    spanUnidad.textContent = '-';

    // Botón eliminar
    const btnElim = document.createElement('button');
    btnElim.type = 'button';
    btnElim.textContent = '✕';
    btnElim.title = 'Eliminar producto';
    btnElim.style.cssText =
      'background:#ef4444;color:#fff;border:none;border-radius:50%;width:28px;height:28px;' +
      'cursor:pointer;font-size:0.9rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;';

    // V16.7.0 GEMINI-MOD — Opciones de modo ácido
    const rowOpcionesAcido = document.createElement('div');
    rowOpcionesAcido.className = 'dosis-opciones-acido';
    rowOpcionesAcido.style.cssText =
      'flex-basis: 100%; display: none; padding: 4px 8px; background: #fefce8; border-radius: 4px; font-size: 0.8rem; color: #854d0e;';
    rowOpcionesAcido.innerHTML = `
      <label style="margin-right: 12px; cursor: pointer;">
        <input type="radio" name="modo_acido_${rowId}" value="ph" checked> Bajar pH
      </label>
      <label style="cursor: pointer;">
        <input type="radio" name="modo_acido_${rowId}" value="alk"> Bajar Alcalinidad
      </label>
    `;

    // ── Eventos ──

    selCat.addEventListener('change', () => {
      const cat = selCat.value;
      selProd.innerHTML = '<option value="">Producto...</option>';
      selProd.disabled = !cat;
      spanUnidad.textContent = '-';
      rowOpcionesAcido.style.display = 'none';

      if (cat && PRODUCTOS_POR_CATEGORIA[cat]) {
        PRODUCTOS_POR_CATEGORIA[cat].forEach((prod) => {
          const opt = document.createElement('option');
          opt.value = prod.clave;
          opt.textContent = prod.nombre;
          opt.dataset.unidad = prod.unidad;
          selProd.appendChild(opt);
        });
      }

      _programarPreviewFila(row);
    });

    // V17.2.3 FIX BUG-002: verificar modo metales al elegir producto
    selProd.addEventListener('change', () => {
      const selected = selProd.selectedOptions[0];
      spanUnidad.textContent = selected?.dataset?.unidad || '-';
      rowOpcionesAcido.style.display =
        (selProd.value === 'acido-muriatico' || selProd.value === 'acido') ? 'block' : 'none';

      // ── V17.2.3 FIX BUG-002 ──
      // Si el modo operativo actual es 'metales' y el producto es clorado, bloquear.
      if (_CLAVES_CLORO.has(selProd.value)) {
        let modoActual = 'rutinario';
        try {
          if (window.DB && typeof DB.getPoolState === 'function' && _albercaActivaId) {
            const ps = DB.getPoolState(_albercaActivaId);
            if (ps && ps.calculado && ps.calculado.modo_operativo) {
              modoActual = ps.calculado.modo_operativo;
            }
          }
        } catch (e) { /* silenciar */ }

        if (modoActual === 'metales') {
          _toast('⛔ Modo metales activo: no se permite añadir cloro. Usa secuestrante.', 'error', 5000);
          // Revertir selección a vacía para que no quede registrada
          selProd.value = '';
          spanUnidad.textContent = '-';
          _renderPreviewImpacto(row, null, 'Producto bloqueado en modo metales.');
          return;
        }
      }
      // ── FIN V17.2.3 FIX BUG-002 ──

      _programarPreviewFila(row);
    });

    rowOpcionesAcido.querySelectorAll('input[type="radio"]').forEach(r => {
      r.addEventListener('change', () => _programarPreviewFila(row));
    });

    inputCant.addEventListener('input', () => _programarPreviewFila(row));
    inputCant.addEventListener('change', () => _programarPreviewFila(row));

    btnElim.addEventListener('click', () => {
      const t = _previewDebounce.get(row.id);
      if (t) { clearTimeout(t); _previewDebounce.delete(row.id); }
      row.remove();
      _actualizarEstadoGuardado();
    });

    row.appendChild(selCat);
    row.appendChild(selProd);
    row.appendChild(inputCant);
    row.appendChild(spanUnidad);
    row.appendChild(btnElim);
    row.appendChild(rowOpcionesAcido);

    container.appendChild(row);

    _renderPreviewImpacto(row, null, 'Ingresa producto y cantidad para ver el impacto químico estimado.');
  }

  /**
   * Recoge todas las filas de dosificación como array.
   * V16.7.0 GEMINI-MOD: incluye modo_acido si aplica.
   * @returns {Array}
   * @private
   */
  function _recogerDosificaciones() {
    const container = $('dosificacion-container');
    if (!container) return [];

    const filas = container.querySelectorAll('.dosis-row');
    const dosificaciones = [];

    filas.forEach((fila) => {
      const selProd = fila.querySelector('.dosis-producto');
      const inputCant = fila.querySelector('.dosis-cantidad');
      const selCat = fila.querySelector('.dosis-categoria');
      const spanUnidad = fila.querySelector('.dosis-unidad');

      if (!selProd || !inputCant) return;

      const clave = selProd.value;
      const cantidad = parseFloat(inputCant.value) || 0;

      if (!clave || cantidad <= 0) return;

      const selected = selProd.selectedOptions[0];

      let modoAcido = undefined;
      if (clave === 'acido-muriatico' || clave === 'acido') {
        const radio = fila.querySelector(`input[name="modo_acido_${fila.id}"]:checked`);
        if (radio) modoAcido = radio.value;
      }

      dosificaciones.push({
        clave,
        nombre: selected?.textContent || clave,
        cantidad,
        unidad: spanUnidad?.textContent || 'g',
        categoria: selCat?.value || '',
        modo_acido: modoAcido
      });
    });

    return dosificaciones;
  }

  // ────────────────────────────────────────────────
  //  ANCLA DE REALIDAD (GUARDAR LECTURA COMO DATO DURO)
  // ────────────────────────────────────────────────

  /**
   * V16.6.4 FIX ANCLA-PARCIAL: ancla solo campos medidos por el técnico.
   * @private
   */
  function _anclarLecturaColorQ() {
    if (!_albercaActivaId) {
      _toast('Selecciona una alberca primero.', 'warning');
      return;
    }

    function _getMedidoOrNull(inputId) {
      var el = document.getElementById(inputId);
      if (!el) return null;
      if (el.classList.contains('colorq-prellenado')) return null;
      if (el.value === '' || el.value === null || el.value === undefined) return null;
      var v = parseFloat(el.value);
      return isNaN(v) ? null : v;
    }

    var ph = _getMedidoOrNull('bit-ph');
    var cloro_libre = _getMedidoOrNull('bit-cloro-libre');

    if (ph === null && cloro_libre === null) {
      _toast('Ingresa al menos pH o Cloro Libre (borra el valor pre-llenado y escribe tu medición).', 'warning');
      return;
    }
    if (ph !== null && (ph < 0 || ph > 14)) {
      _toast('pH debe estar entre 0 y 14.', 'warning');
      return;
    }
    if (cloro_libre !== null && (cloro_libre < 0 || cloro_libre > 20)) {
      _toast('Cloro libre debe estar entre 0 y 20 ppm.', 'warning');
      return;
    }

    var data = {
      cloro_libre: cloro_libre,
      ph: ph,
      alcalinidad: _getMedidoOrNull('bit-alcalinidad'),
      dureza_calcica: _getMedidoOrNull('bit-dureza'),
      cianurico: _getMedidoOrNull('bit-cianurico'),
      tds: _getMedidoOrNull('bit-tds'),
      temperatura: _getMedidoOrNull('bit-temperatura'),
      cloro_total: _getMedidoOrNull('bit-cloro-total'),
      notas_tecnico: 'Lectura ColorQ Pro 7 — Dato duro anclado. Solo los campos medidos por el técnico actualizan el gemelo.',
      fuente: 'ColorQ'
    };

    try {
      if (window.DB) {
        DB.saveRegistro(_albercaActivaId, data);
      }
      _toast('Lectura anclada. Solo los campos que mediste actualizan el gemelo.', 'success');
      _recalcularTodosLosPreviews();
    } catch (err) {
      console.error('[Bitácora] Error al anclar lectura:', err);
      _toast('Error al guardar lectura: ' + err.message, 'error');
    }
  }

  // ────────────────────────────────────────────────
  //  CONSTRUCCIÓN Y GUARDADO DEL SERVICIO
  // ────────────────────────────────────────────────

  /**
   * V17.2.0 MOD: contrato JSON V17.2.
   * @returns {Object|null}
   * @private
   */
  function _construirObjetoServicio() {
    if (!_albercaActivaId) {
      _toast('Selecciona una alberca antes de guardar.', 'error');
      return null;
    }

    const ahora = new Date().toISOString();
    const idServicio = 'srv_' + Date.now() + '_' + Math.random().toString(36).substr(2, 6);

    const tipoServicio = document.getElementById('bit-tipo')?.value || '';
    const tipoAlgaServ = document.getElementById('bit-tipo-alga')?.value || null;
    const metalPres = document.getElementById('bit-metal-presunto')?.value || null;
    const recubConf = document.getElementById('bit-recubrimiento-confirmado')?.value || null;

    const saludAgua = {
      claridad_actual: parseInt(document.getElementById('bit-claridad')?.value, 10),
      naturaleza_color: document.querySelector('input[name="bit-naturaleza-color"]:checked')?.value || 'ninguna',
      tipo_alga: document.getElementById('bit-tipo-alga-presunta')?.value || 'ninguna',
      visibilidad_fondo_m: parseFloat(document.getElementById('bit-visibilidad-fondo')?.value) || null,
      profundidad_visible_m: parseFloat(document.getElementById('bit-profundidad-visible')?.value) || null,
      olor: document.getElementById('bit-olor')?.value || 'ninguno'
    };

    const lecturaColorQ = _recogerLecturaColorQ();

    const estadoHidraulico = {
      psi_llegada: parseFloat(document.getElementById('bit-psi-llegada')?.value) || null,
      nivel_vaso: document.getElementById('bit-nivel-vaso')?.value || 'normal',
      observacion_bomba: document.getElementById('bit-obs-bomba')?.value || '',
      observacion_filtro: document.getElementById('bit-obs-filtro')?.value || ''
    };

    let aguaLlenado = null;
    const litrosLlenado = parseFloat(document.getElementById('bit-litros-llenado')?.value) || 0;
    if (litrosLlenado > 0) {
      aguaLlenado = {
        fuente: document.getElementById('bit-fuente-agua')?.value || 'red',
        ph: parseFloat(document.getElementById('bit-llenado-ph')?.value) || null,
        alcalinidad: parseFloat(document.getElementById('bit-llenado-alk')?.value) || null,
        dureza: parseFloat(document.getElementById('bit-llenado-dureza')?.value) || null,
        cianurico: parseFloat(document.getElementById('bit-llenado-cya')?.value) || null,
        tds: parseFloat(document.getElementById('bit-llenado-tds')?.value) || null,
        temperatura: parseFloat(document.getElementById('bit-llenado-temp')?.value) || null,
        litros_aportados: litrosLlenado
      };
    }

    const poolState = (window.DB && DB.getPoolState) ? DB.getPoolState(_albercaActivaId) : null;
    const modoActivo = (poolState && poolState.calculado && poolState.calculado.modo_operativo)
                       ? poolState.calculado.modo_operativo : 'rutinario';

    return {
      id: idServicio,
      pool_id: _albercaActivaId,
      timestamp: ahora,
      tecnico: _strVal('bit-tecnico', 'Omar Valle'),
      firma: FIRMA,
      version_bitacora: VERSION,

      tipo_servicio: tipoServicio,
      tipo_alga: tipoAlgaServ,
      metal_presunto: metalPres,
      recubrimiento_confirmado: recubConf,
      modo_operativo_activo: modoActivo,

      salud_agua: saludAgua,
      lectura_colorq: lecturaColorQ,
      estado_hidraulico_llegada: estadoHidraulico,
      agua_llenado: aguaLlenado,
      checklist_mecanico: _recogerChecklist(),
      tiempos_operacion: _recogerTiemposOperacion(),
      balance_hidrico: _recogerBalanceHidrico(),
      dosificaciones: _recogerDosificaciones(),
      factores_externos: _recogerFactoresExternos(),
      observaciones: document.getElementById('bit-observaciones')?.value || '',
      diagnostico_anclado_en: window.__bitacoraUltimoAncla || null,
      descontar_inventario: document.getElementById('bit-descontar-inv')?.checked !== false
    };
  }

  function _recogerLecturaColorQ() {
    return {
      ph: _numVal('bit-ph'),
      cloro_libre: _numVal('bit-cloro-libre'),
      cloro_total: _numVal('bit-cloro-total'),
      cloro_combinado: _numVal('bit-cloro-combinado'),
      alcalinidad: _numVal('bit-alcalinidad'),
      dureza_calcica: _numVal('bit-dureza'),
      cianurico: _numVal('bit-cianurico'),
      tds: _numVal('bit-tds'),
      temperatura: _numVal('bit-temperatura'),
      turbidez: _strVal('bit-turbidez', 'cristalina')
    };
  }

  function _recogerChecklist() {
    return {
      cepillado: _checked('chk-cepillado'),
      aspirado: _checked('chk-aspirado'),
      canastillas: _checked('chk-canastillas'),
      red_hojas: _checked('chk-red'),
      filtro_presion: _checked('chk-filtro'),
      nivel_agua: _checked('chk-nivel')
    };
  }

  function _recogerTiemposOperacion() {
    return {
      horas_filtracion: _numVal('bit-horas-filtracion'),
      horas_hidrojets: _numVal('bit-horas-hidrojets'),
      horas_cascadas: _numVal('bit-horas-cascadas')
    };
  }

  function _recogerBalanceHidrico() {
    const retroMin = _numVal('bit-duracion-min');
    const llenadoLitros = _numVal('bit-litros-llenado');
    let litrosRetro = 0;
    if (retroMin > 0 && _gemeloActivo) {
      const flujo = parseFloat(_gemeloActivo.auditoria_hidraulica?.bomba?.flujo_real_lpm) || 0;
      litrosRetro = parseFloat((retroMin * flujo).toFixed(1));
    }
    return {
      retrolavado: { realizado: retroMin > 0, duracion_min: retroMin, litros_perdidos: litrosRetro },
      llenado: { realizado: llenadoLitros > 0, litros_agregados: llenadoLitros }
    };
  }

  function _recogerFactoresExternos() {
    return {
      evento_norte: _checked('chk-evento-norte'),
      lluvia_intensa: _checked('chk-lluvia'),
      pool_party: _checked('chk-pool-party'),
      hojas_materia_organica: _checked('chk-hojas')
    };
  }

  // ────────────────────────────────────────────────
  //  GUARDADO DE BITÁCORA
  // ────────────────────────────────────────────────

  /**
   * Guarda la bitácora completa.
   * V16.7.0 MOD: aborta si hay filas bloqueadas.
   * V16.7.0 GEMINI-MOD: propaga modo_acido.
   * V17.2.3 FIX N-02: persistencia vía DB.saveServicio (elimina bloque
   *   localStorage directo). Sin localStorage en este módulo.
   * @private
   */
  function _guardarBitacora() {
    try {
      // Guarda de seguridad: si alguna fila está bloqueada, abortar.
      const containerDos = $('dosificacion-container');
      const bloqueadas = containerDos ? containerDos.querySelectorAll('.dosis-row.dosis-bloqueada').length : 0;
      if (bloqueadas > 0) {
        _toast(`No se puede guardar: ${bloqueadas} dosis fuera de rango seguro. Ajusta antes de continuar.`, 'error', 4500);
        return;
      }

      const servicio = _construirObjetoServicio();
      if (!servicio) return;

      // ── 1. Descontar inventario ──
      if (servicio.descontar_inventario && servicio.dosificaciones.length > 0 && window.DB) {
        servicio.dosificaciones.forEach((dosis) => {
          try {
            DB.descontarInventario(dosis.clave, dosis.cantidad);
          } catch (err) {
            console.warn(`[Bitácora] No se pudo descontar ${dosis.clave}:`, err.message);
          }
        });
      }

      // ── 2. Guardar lectura ColorQ como registro (si tiene datos) ──
      const lc = servicio.lectura_colorq;
      const tieneColorQ = lc.ph > 0 || lc.cloro_libre > 0;

      if (tieneColorQ && window.DB) {
        try {
          DB.saveRegistro(servicio.pool_id, {
            cloro_libre: lc.cloro_libre,
            ph: lc.ph,
            alcalinidad: lc.alcalinidad,
            dureza_calcica: lc.dureza_calcica,
            cianurico: lc.cianurico,
            tds: lc.tds,
            temperatura: lc.temperatura,
            notas_tecnico: `Bitácora ${servicio.tipo_servicio} — ${servicio.tecnico}`,
            fuente: 'ColorQ'
          });
        } catch (err) {
          console.warn('[Bitácora] Error al guardar registro ColorQ:', err.message);
        }
      }

      // ── 3. Persistir el servicio ── V17.2.3 FIX N-02
      if (window.DB && typeof window.DB.saveServicio === 'function') {
        try {
          DB.saveServicio(servicio.pool_id, servicio);
        } catch (err) {
          console.error('[Bitácora] Error al guardar servicio:', err);
          _toast('Error al guardar bitácora');
        }
      } else {
        console.error('[Bitácora] DB.saveServicio no disponible');
        _toast('Error: DB no disponible');
      }

      // ── 4. Disparar eventos para el Engine ──
      if (window.EventBus) {
        if (servicio.balance_hidrico && servicio.balance_hidrico.retrolavado.realizado) {
          window.EventBus.dispatch('bitacora:guardada', {
            poolId: servicio.pool_id,
            tipo: 'RETROLAVADO',
            tipoEvento: 'RETROLAVADO',
            litros_perdidos: servicio.balance_hidrico.retrolavado.litros_perdidos,
            duracion_min: servicio.balance_hidrico.retrolavado.duracion_min,
            timestamp: servicio.timestamp
          });
        }

        if (servicio.balance_hidrico && servicio.balance_hidrico.llenado.realizado) {
          const volActualL = (parseFloat(_gemeloActivo?.geometria_adn?.volumen_m3) || 0) * 1000;
          window.EventBus.dispatch('bitacora:guardada', {
            poolId: servicio.pool_id,
            tipo: 'LLENADO',
            tipoEvento: 'LLENADO',
            litros_agregados: servicio.balance_hidrico.llenado.litros_agregados,
            volumen_actual_litros: volActualL,
            timestamp: servicio.timestamp
          });
        }

        if (servicio.dosificaciones.length > 0) {
          const pzq = (_gemeloActivo && _gemeloActivo.punto_cero_quimico) || {};
          const geo = (_gemeloActivo && _gemeloActivo.geometria_adn) || {};
          const recubrimientoCtx = (geo.recubrimiento && geo.recubrimiento.tipo)
            ? String(geo.recubrimiento.tipo).toLowerCase()
            : 'porcelanato';

          const contextoGemelo = {
            ph:             lc.ph             || pzq.ph             || 7.4,
            alcalinidad:    lc.alcalinidad    || pzq.alcalinidad    || 100,
            temperatura:    lc.temperatura    || pzq.temperatura_llenado || 28,
            dureza:         lc.dureza_calcica || pzq.dureza         || 250,
            cianurico:      lc.cianurico      || pzq.cianurico      || 30,
            tds:            lc.tds            || 0,
            recubrimiento:  recubrimientoCtx
          };

          const deltas = {};
          const tieneFnNueva = window.Chemistry &&
                               typeof window.Chemistry.calcDeltaPorAplicacion === 'function';

          if (!tieneFnNueva) {
            console.warn('[Bitácora] Chemistry.calcDeltaPorAplicacion no disponible. ' +
                         'Actualiza chemistry.js a V16.4.2. Deltas omitidos para no corromper el gemelo.');
          } else if (_gemeloActivo) {
            const volM3 = parseFloat(geo.volumen_m3) || 50;

          // V17.2.4 MOD FIX DELTA-PH-RESCATE: usar wrapper inteligente
            const modoOpServicio = servicio.modo_operativo_activo || 'rutinario';

            servicio.dosificaciones.forEach((dosis) => {
              try {
                const unidadLower = (dosis.unidad || '').toString().toLowerCase();
                const ctxDosis = Object.assign({}, contextoGemelo);
                if (dosis.modo_acido) ctxDosis.modo_acido = dosis.modo_acido;

                const res = _calcularDeltasInteligente(
                  dosis.clave, dosis.cantidad, unidadLower, volM3, ctxDosis, modoOpServicio
                );
                if (res) {
                  if (res.deltaCl  != null) deltas.cloro_libre    = (deltas.cloro_libre    || 0) + res.deltaCl;
                  if (res.deltaCYA != null) deltas.cianurico      = (deltas.cianurico      || 0) + res.deltaCYA;
                  if (res.deltaCH  != null) deltas.dureza_calcica = (deltas.dureza_calcica || 0) + res.deltaCH;
                  if (res.deltaALK != null) deltas.alcalinidad    = (deltas.alcalinidad    || 0) + res.deltaALK;
                  if (res.deltaPH  != null) deltas.ph             = (deltas.ph             || 0) + res.deltaPH;

                  // Log diagnóstico del motor usado
                  console.info('[Bitácora V17.2.4]', dosis.clave, 'motor:', res._motor_usado || 'desconocido',
                               '| ΔpH:', res.deltaPH, '| ΔALK:', res.deltaALK);
                }
              } catch (e) {
                console.warn('[Bitácora V17.2.4] Cálculo de deltas falló para', dosis.clave, e);
              }
            });
            // V17.2.4 END MOD
          }

          if (Object.keys(deltas).length > 0) {
            window.EventBus.dispatch('bitacora:guardada', {
              poolId: servicio.pool_id,
              tipo: 'DOSIFICACION',
              tipoEvento: 'DOSIFICACION',
              deltas,
              dosificaciones: servicio.dosificaciones,
              timestamp: servicio.timestamp
            });
          }
        }

        window.EventBus.dispatch('bitacora:servicio_completo', {
          poolId: servicio.pool_id,
          servicioId: servicio.id,
          tipo_servicio: servicio.tipo_servicio,
          timestamp: servicio.timestamp
        });
      }

      // ── 5. Fotos ya no se guardan (V17.2.0 REMOVED) ──

      // ── 6. Confirmación ──
      _toast('Bitácora guardada exitosamente.', 'success', 4000);
      console.info(`[Bitácora] Servicio ${servicio.id} guardado para ${servicio.pool_id}.`);

      _resetFormulario();

    } catch (err) {
      console.error('[Bitácora] Error crítico al guardar:', err);
      _toast('Error al guardar bitácora: ' + err.message, 'error', 5000);
    }
  }

  // ────────────────────────────────────────────────
  //  REPORTE WHATSAPP
  // ────────────────────────────────────────────────

  /**
   * Genera el texto de resumen para WhatsApp.
   * V16.7.0 GEMINI-MOD: anota modo ácido.
   * @returns {string}
   * @private
   */
  function _generarResumenWhatsApp() {
    const servicio = _construirObjetoServicio();
    if (!servicio) return '';

    const gemelo = _gemeloActivo;
    const alias = gemelo?.metadata?.alias_alberca || 'Alberca';
    const cliente = gemelo?.metadata?.cliente || '';
    const lc = servicio.lectura_colorq;

    let texto = `🏊 *Pool Balance — Reporte de Servicio*\n`;
    texto += `━━━━━━━━━━━━━━━━━━━\n`;
    texto += `📍 *${alias}*${cliente ? ` (${cliente})` : ''}\n`;
    texto += `📅 ${new Date(servicio.timestamp).toLocaleDateString('es-MX', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}\n`;
    texto += `👷 ${servicio.tecnico}\n`;
    texto += `🔧 ${TIPOS_SERVICIO.find(t => t.value === servicio.tipo_servicio)?.label || servicio.tipo_servicio}\n`;
    texto += `\n`;

    const checks = [];
    if (servicio.checklist_mecanico.cepillado) checks.push('Cepillado');
    if (servicio.checklist_mecanico.aspirado) checks.push('Aspirado');
    if (servicio.checklist_mecanico.canastillas) checks.push('Canastillas');
    if (servicio.checklist_mecanico.red_hojas) checks.push('Red/Hojas');
    if (servicio.checklist_mecanico.filtro_presion) checks.push('Filtro/Presión');
    if (servicio.checklist_mecanico.nivel_agua) checks.push('Nivel agua');
    if (checks.length > 0) texto += `✅ *Checklist:* ${checks.join(', ')}\n`;

    if (servicio.estado_hidraulico_llegada.psi_llegada > 0) {
      texto += `🔴 Presión filtro: ${servicio.estado_hidraulico_llegada.psi_llegada} PSI\n`;
    }

    texto += `\n`;

    if (lc.ph > 0 || lc.cloro_libre > 0) {
      texto += `📊 *Lectura ColorQ Pro 7:*\n`;
      if (lc.ph > 0) texto += `   pH: ${lc.ph}\n`;
      if (lc.cloro_libre > 0) texto += `   Cl libre: ${lc.cloro_libre} ppm\n`;
      if (lc.cloro_combinado > 0) texto += `   Cl combinado: ${lc.cloro_combinado} ppm\n`;
      if (lc.alcalinidad > 0) texto += `   Alcalinidad: ${lc.alcalinidad} ppm\n`;
      if (lc.dureza_calcica > 0) texto += `   Dureza Ca: ${lc.dureza_calcica} ppm\n`;
      if (lc.cianurico > 0) texto += `   CYA: ${lc.cianurico} ppm\n`;
      if (lc.tds > 0) texto += `   TDS: ${lc.tds} ppm\n`;
      if (lc.temperatura > 0) texto += `   Temp: ${lc.temperatura}°C\n`;
      texto += `   Turbidez: ${lc.turbidez}\n`;

      if (window.Calculadoras) {
        const isv = window.Calculadoras.calcISVRapido({
          ph: lc.ph, temperatura: lc.temperatura,
          dureza: lc.dureza_calcica, alcalinidad: lc.alcalinidad,
          cianurico: lc.cianurico, tds: lc.tds,
          recubrimiento: gemelo?.geometria_adn?.recubrimiento?.tipo?.toLowerCase() || 'porcelanato'
        });
        if (isv) texto += `   *ISV: ${isv.isv} (${isv.estado})*\n`;
      }
      texto += `\n`;
    }

    if (servicio.balance_hidrico.retrolavado.realizado) {
      texto += `🔄 *Retrolavado:* ${servicio.balance_hidrico.retrolavado.duracion_min} min → ${servicio.balance_hidrico.retrolavado.litros_perdidos.toLocaleString('es-MX')} L\n`;
    }
    if (servicio.balance_hidrico.llenado.realizado) {
      texto += `💧 *Llenado:* ${servicio.balance_hidrico.llenado.litros_agregados.toLocaleString('es-MX')} L\n`;
    }

    if (servicio.dosificaciones.length > 0) {
      texto += `\n🧪 *Dosificación:*\n`;
      servicio.dosificaciones.forEach((d) => {
        const anotacionModo = d.modo_acido === 'alk' ? ' (Modo: Bajar ALK)' :
                              d.modo_acido === 'ph'  ? ' (Modo: Bajar pH)'  : '';
        texto += `   • ${d.nombre}: ${d.cantidad} ${d.unidad}${anotacionModo}\n`;
      });
    }

    const factores = [];
    if (servicio.factores_externos.evento_norte) factores.push('Norte/Viento');
    if (servicio.factores_externos.lluvia_intensa) factores.push('Lluvia');
    if (servicio.factores_externos.pool_party) factores.push('Pool Party');
    if (servicio.factores_externos.hojas_materia_organica) factores.push('Hojas/MO');
    if (factores.length > 0) texto += `\n🌦️ *Factores externos:* ${factores.join(', ')}\n`;

    if (servicio.observaciones) texto += `\n📝 *Observaciones:* ${servicio.observaciones}\n`;

    texto += `\n━━━━━━━━━━━━━━━━━━━\n`;
    texto += `🔬 Pool Balance V15 · Gemelo Digital\n`;
    texto += `${FIRMA}`;

    return texto;
  }

  function _vistaPrevia() {
    const texto = _generarResumenWhatsApp();
    if (!texto) return;

    const panel = $('reporte-preview');
    if (panel) {
      panel.style.display = 'block';
      panel.innerHTML = `<pre style="white-space:pre-wrap;font-size:0.82rem;padding:12px;
        background:#f0f9ff;border-radius:8px;border:1px solid #bae6fd;max-height:400px;
        overflow-y:auto;font-family:system-ui,sans-serif">${texto}</pre>`;
    }
  }

  function _enviarWhatsApp() {
    const texto = _generarResumenWhatsApp();
    if (!texto) return;

    let numero = _gemeloActivo?.metadata?.wa_contacto || '';
    if (!numero) {
      window.open(`https://wa.me/?text=${encodeURIComponent(texto)}`, '_blank');
      return;
    }
    numero = numero.replace(/[^0-9]/g, '');
    window.open(`https://wa.me/${numero}?text=${encodeURIComponent(texto)}`, '_blank');
  }

  // ────────────────────────────────────────────────
  //  RESET DEL FORMULARIO
  // ────────────────────────────────────────────────

  function _resetFormulario() {
    if (_cronometroRetroActivo) {
      clearInterval(_cronometroRetroInterval);
      _cronometroRetroActivo = false;
    }
    if (_cronometroLlenadoActivo) {
      clearInterval(_cronometroLlenadoInterval);
      _cronometroLlenadoActivo = false;
    }
    _cronometroRetroSegundos = 0;
    _cronometroLlenadoSegundos = 0;

    const cronoRetro = $('crono-retro-display');
    if (cronoRetro) cronoRetro.textContent = '00:00';
    const cronoLlenado = $('crono-llenado-display');
    if (cronoLlenado) cronoLlenado.textContent = '00:00';

    const btnIniciarRetro = $('btn-iniciar-retro');
    if (btnIniciarRetro) btnIniciarRetro.disabled = false;
    const btnDetenerRetro = $('btn-detener-retro');
    if (btnDetenerRetro) { btnDetenerRetro.disabled = true; btnDetenerRetro.textContent = 'Detener Retrolavado'; }
    const btnIniciarLlenado = $('btn-iniciar-llenado');
    if (btnIniciarLlenado) btnIniciarLlenado.disabled = false;
    const btnDetenerLlenado = $('btn-detener-llenado');
    if (btnDetenerLlenado) { btnDetenerLlenado.disabled = true; btnDetenerLlenado.textContent = 'Detener Llenado'; }

    const dosContainer = $('dosificacion-container');
    if (dosContainer) dosContainer.innerHTML = '';

    _previewDebounce.forEach((t) => clearTimeout(t));
    _previewDebounce.clear();
    _actualizarEstadoGuardado();

    const retroReport = $('retro-live-report');
    if (retroReport) retroReport.innerHTML = '';
    const llenadoReport = $('llenado-live-report');
    if (llenadoReport) llenadoReport.innerHTML = '';
    const previewReport = $('reporte-preview');
    if (previewReport) { previewReport.innerHTML = ''; previewReport.style.display = 'none'; }

    const camposLimpiar = [
      'bit-presion-llegada', 'bit-horas-filtracion', 'bit-horas-hidrojets', 'bit-horas-cascadas',
      'bit-ph', 'bit-cloro-libre', 'bit-cloro-total', 'bit-cloro-combinado',
      'bit-alcalinidad', 'bit-dureza', 'bit-cianurico', 'bit-tds', 'bit-temperatura',
      'bit-duracion-min', 'bit-litros-llenado', 'bit-observaciones'
    ];
    camposLimpiar.forEach((id) => { const el = $(id); if (el) el.value = ''; });

    const checkboxes = [
      'chk-cepillado', 'chk-aspirado', 'chk-canastillas', 'chk-red',
      'chk-filtro', 'chk-nivel', 'chk-evento-norte', 'chk-lluvia',
      'chk-pool-party', 'chk-hojas'
    ];
    checkboxes.forEach((id) => { const el = $(id); if (el) el.checked = false; });

    const descInv = $('bit-descontar-inv');
    if (descInv) descInv.checked = true;

    const turbidez = $('bit-turbidez');
    if (turbidez) turbidez.value = 'cristalina';

    const fecha = $('bit-fecha');
    if (fecha) fecha.value = _nowDatetimeLocal();

    _dosificacionRowCounter = 0;
    window.__bitacoraUltimoAncla = null;
  }

  // ────────────────────────────────────────────────
  //  MÓDULO PÚBLICO: BITACORA
  // ────────────────────────────────────────────────

  const Bitacora = {

    /** V17.2.3 — Versión pública del módulo. */
    VERSION: VERSION,

    init() {
      if (!window.DB)       console.warn('[Bitácora] window.DB no disponible. Persistencia limitada.');
      if (!window.EventBus) console.warn('[Bitácora] window.EventBus no disponible. Sin comunicación con Engine.');
      if (!window.Chemistry) console.warn('[Bitácora] window.Chemistry no disponible. Cálculos limitados.');

      _cargarSelectorAlbercas();

      const fecha = $('bit-fecha');
      if (fecha) fecha.value = _nowDatetimeLocal();

      const tecnico = $('bit-tecnico');
      if (tecnico) {
        const tecnicoGuardado = localStorage.getItem('pb_tecnico_nombre') || 'Omar Alberto Valle Mercado';
        tecnico.value = tecnicoGuardado;
        tecnico.addEventListener('change', () => {
          localStorage.setItem('pb_tecnico_nombre', tecnico.value);
        });
      }

      const descInv = $('bit-descontar-inv');
      if (descInv) descInv.checked = true;

      _bindEvent('bit-alberca', 'change', _onAlbercaChange);
      _bindEvent('btn-anclar-colorq', 'click', _anclarLecturaColorQ);

      _bindEvent('bit-cloro-libre', 'input', _calcularCloroCombinado);
      _bindEvent('bit-cloro-total', 'input', _calcularCloroCombinado);

      const camposCtxQuim = ['bit-ph', 'bit-alcalinidad', 'bit-temperatura',
                             'bit-dureza', 'bit-cianurico', 'bit-tds'];
      camposCtxQuim.forEach((id) => {
        const el = $(id);
        if (el) el.addEventListener('input', () => _recalcularTodosLosPreviews());
      });

      _bindEvent('btn-iniciar-retro', 'click', _iniciarCronoRetro);
      _bindEvent('btn-detener-retro', 'click', _detenerCronoRetro);
      _bindEvent('btn-iniciar-llenado', 'click', _iniciarCronoLlenado);
      _bindEvent('btn-detener-llenado', 'click', _detenerCronoLlenado);

      _bindEvent('bit-duracion-min', 'input', _actualizarReporteRetroVivo);
      _bindEvent('bit-litros-llenado', 'input', _actualizarReporteLlenadoVivo);

      _bindEvent('btn-agregar-dosificacion', 'click', _agregarFilaDosificacion);

      _bindEvent('btn-guardar-bitacora', 'click', _guardarBitacora);
      _bindEvent('btn-vista-previa', 'click', _vistaPrevia);
      _bindEvent('btn-enviar-whatsapp', 'click', _enviarWhatsApp);

      // V17.2.0 ADD: listeners reactivos
      const tipoSel = document.getElementById('bit-tipo');
      if (tipoSel) {
        tipoSel.addEventListener('change', function() {
          _actualizarSubselectoresTipo();
          _evaluarOverrideTipoServicio();
          _recalcularTodosLosPreviews();
        });
      }

      ['bit-claridad','bit-tipo-alga-presunta'].forEach(function(id) {
        const el = document.getElementById(id);
        if (el) el.addEventListener('change', function() {
          _evaluarOverrideTipoServicio();
          _recalcularTodosLosPreviews();
        });
      });

      document.querySelectorAll('input[name="bit-naturaleza-color"]').forEach(function(r) {
        r.addEventListener('change', function() {
          _evaluarOverrideTipoServicio();
          _recalcularTodosLosPreviews();
        });
      });

      const psiInp = document.getElementById('bit-psi-llegada');
      if (psiInp) {
        psiInp.addEventListener('input', function() {
          const poolId = _albercaActivaId;
          const alberca = (poolId && window.DB) ? DB.getAlberca(poolId) : null;
          const psiLimpio = (alberca && alberca.equipo && alberca.equipo.psi_limpio)
                            ? parseFloat(alberca.equipo.psi_limpio) : null;
          const psiAct = parseFloat(psiInp.value) || null;
          const hint = document.getElementById('bit-psi-hint');
          if (!hint) return;
          if (psiAct !== null && psiLimpio !== null) {
            const delta = psiAct - psiLimpio;
            if (delta > 8) {
              hint.textContent = 'Presión actual ' + psiAct + ' PSI vs limpio ' + psiLimpio +
                                 ' PSI. Delta ' + delta.toFixed(0) + ' PSI. Considera retrolavado.';
              hint.style.color = '#b45309';
            } else {
              hint.textContent = 'Delta: ' + delta.toFixed(0) + ' PSI (OK)';
              hint.style.color = '#666';
            }
          } else {
            hint.textContent = '';
          }
        });
      }

      const btnAnclar = document.getElementById('bit-btn-anclar-diagnostico');
      if (btnAnclar) {
        btnAnclar.addEventListener('click', function() { _anclarDiagnostico(); });
      }

      // Suscripciones EventBus
      if (window.EventBus) {
        window.EventBus.on('alberca:created', _cargarSelectorAlbercas);
        window.EventBus.on('alberca:updated', _cargarSelectorAlbercas);
        window.EventBus.on('alberca:deleted', () => {
          _cargarSelectorAlbercas();
          if (_albercaActivaId) {
            const existe = window.DB ? DB.getAlberca(_albercaActivaId) : null;
            if (!existe) { _albercaActivaId = null; _gemeloActivo = null; }
          }
        });
      }

      console.info(`[Bitácora] Módulo inicializado. Pool Balance V${VERSION}.`);
      return true;
    },

    seleccionarAlberca(poolId) {
      const select = $('bit-alberca');
      if (select && poolId) {
        select.value = poolId;
        _onAlbercaChange();
      }
    },

    getAlbercaActiva() {
      return _albercaActivaId;
    },

    generarResumen() {
      return _generarResumenWhatsApp();
    },

    reset() {
      _resetFormulario();
    }
  };

  function _bindEvent(id, evento, handler) {
    const el = $(id);
    if (el) el.addEventListener(evento, handler);
  }

  window.Bitacora = Bitacora;

  // V17.2.3 — Log de carga con versión.
  console.info(
    `[Bitácora] V${VERSION} cargado · ` +
    `FIX N-02: DB.saveServicio · ` +
    `FIX BUG-007: diagnostico_anclado completo + Engine.proyectarEstadoActual · ` +
    `FIX BUG-002: bloqueo cloro modo metales · ` +
    `FIX DELTA-PH-RESCATE: Entregable F en rescate/severa/ALK<80`
  );

})();
