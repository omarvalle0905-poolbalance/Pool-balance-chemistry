  /**
   * Carga la lista de albercas en el selector.
   * @private
   */
  function _cargarSelectorAlbercas() {
    const select = $('bit-alberca');
    if (!select) return;

    select.innerHTML = '<option value="">— Selecciona alberca —</option>';

    if (!window.DB) return;

    const albercas = DB.getAlbercas();
    albercas.forEach((alb) => {
      const opt = document.createElement('option');
      opt.value = alb.id;
      const alias = alb.metadata?.alias_alberca || 'Sin nombre';
      const cliente = alb.metadata?.cliente || '';
      opt.textContent = cliente ? `${alias} (${cliente})` : alias;
      select.appendChild(opt);
    });
  }

  /**
   * Pre-llena campos con datos del Gemelo Digital activo.
   * @param {Object} gemelo
   * @private
   */
  function _prellenarDatosGemelo(gemelo) {
    if (!gemelo) return;

    const geo = gemelo.geometria_adn || {};
    const hid = gemelo.auditoria_hidraulica || {};
    const pzq = gemelo.punto_cero_quimico || {};

    const volInfo = $('bit-info-volumen');
    if (volInfo) volInfo.textContent = `${geo.volumen_m3 || 0} m³ (${((geo.volumen_m3 || 0) * 1000).toFixed(0)} L)`;

    const flujoInfo = $('bit-info-flujo-desague');
    if (flujoInfo) flujoInfo.textContent = `${hid.bomba?.flujo_real_lpm || 0} LPM`;

    const flujoLlenadoInfo = $('bit-info-flujo-llenado');
    if (flujoLlenadoInfo) flujoLlenadoInfo.textContent = `${hid.bomba?.flujo_llenado_lpm || 0} LPM`;

    const psiInfo = $('bit-info-psi-limpio');
    if (psiInfo) psiInfo.textContent = `${hid.filtro?.psi_limpio || 0} PSI`;

    const cyaBase = $('bit-info-cya-base');
    if (cyaBase) cyaBase.textContent = `${pzq.cianurico || 0} ppm`;

    const durezaBase = $('bit-info-dureza-base');
    if (durezaBase) durezaBase.textContent = `${pzq.dureza || 0} ppm`;

    if (window.DB) {
      const ultimo = DB.getUltimoRegistro(gemelo.id);
      if (ultimo && ultimo.parametros) {
        const tempField = $('bit-temperatura');
        if (tempField && !tempField.value) {
          tempField.value = ultimo.parametros.temperatura || '';
        }
      }
    }
  }

  /**
   * Se ejecuta cuando el técnico cambia la alberca seleccionada.
   * @private
   */
  function _onAlbercaChange() {
    const select = $('bit-alberca');
    if (!select) return;

    _albercaActivaId = select.value || null;

    if (!_albercaActivaId || !window.DB) {
      _gemeloActivo = null;
      _recalcularTodosLosPreviews();
      return;
    }

    _gemeloActivo = DB.getAlberca(_albercaActivaId);
    _prellenarDatosGemelo(_gemeloActivo);

    if (window.EventBus) {
      window.EventBus.dispatch('bitacora:alberca_seleccionada', {
        poolId: _albercaActivaId,
        alias: _gemeloActivo?.metadata?.alias_alberca || '',
        timestamp: _nowISO()
      });
    }

    _recalcularTodosLosPreviews();

    console.info(`[Bitácora] Alberca activa: ${_albercaActivaId}`);
  }

  // ────────────────────────────────────────────────
  //  CRONÓMETRO DE RETROLAVADO
  // ────────────────────────────────────────────────

  function _iniciarCronoRetro() {
    if (_cronometroRetroActivo) return;

    _cronometroRetroActivo = true;
    _cronometroRetroSegundos = 0;
    _retroDetenerPrimerClic = false;

    const display = $('crono-retro-display');
    const btnIniciar = $('btn-iniciar-retro');
    const btnDetener = $('btn-detener-retro');

    if (display) display.textContent = '00:00';
    if (btnIniciar) btnIniciar.disabled = true;
    if (btnDetener) {
      btnDetener.disabled = false;
      btnDetener.textContent = 'Detener Retrolavado';
    }

    _cronometroRetroInterval = setInterval(() => {
      _cronometroRetroSegundos++;
      if (display) display.textContent = _formatCrono(_cronometroRetroSegundos);
      if (_cronometroRetroSegundos % 10 === 0) _actualizarReporteRetroVivo();
    }, 1000);

    _toast('Cronómetro de retrolavado iniciado', 'info');
  }

  function _detenerCronoRetro() {
    if (!_cronometroRetroActivo) return;

    if (!_retroDetenerPrimerClic) {
      _retroDetenerPrimerClic = true;
      const btnDetener = $('btn-detener-retro');
      if (btnDetener) {
        btnDetener.textContent = '⚠️ Clic de nuevo para CONFIRMAR';
        btnDetener.style.background = '#f59e0b';
      }
      _retroDetenerTimeout = setTimeout(() => {
        _retroDetenerPrimerClic = false;
        if (btnDetener) {
          btnDetener.textContent = 'Detener Retrolavado';
          btnDetener.style.background = '';
        }
      }, 3000);
      return;
    }

    clearTimeout(_retroDetenerTimeout);
    clearInterval(_cronometroRetroInterval);
    _cronometroRetroActivo = false;
    _retroDetenerPrimerClic = false;

    const btnIniciar = $('btn-iniciar-retro');
    const btnDetener = $('btn-detener-retro');

    if (btnIniciar) btnIniciar.disabled = false;
    if (btnDetener) {
      btnDetener.disabled = true;
      btnDetener.textContent = 'Detener Retrolavado';
      btnDetener.style.background = '';
    }

    const minutos = _cronometroRetroSegundos / 60;
    const campoMin = $('bit-duracion-min');
    if (campoMin) campoMin.value = minutos.toFixed(1);

    _actualizarReporteRetroVivo();
    _toast(`Retrolavado: ${_formatCrono(_cronometroRetroSegundos)} (${minutos.toFixed(1)} min)`, 'success');
  }

  function _actualizarReporteRetroVivo() {
    const panel = $('retro-live-report');
    if (!panel) return;

    const minutos = _cronometroRetroActivo
      ? _cronometroRetroSegundos / 60
      : _numVal('bit-duracion-min', 0);

    if (minutos <= 0 || !_gemeloActivo) {
      panel.innerHTML = '<span style="color:var(--text-muted);font-size:0.82rem">' +
        '⏱️ Ingresa el tiempo para calcular el impacto de masa.</span>';
      return;
    }

    const flujoDesague = parseFloat(_gemeloActivo.auditoria_hidraulica?.bomba?.flujo_real_lpm) || 0;
    const volM3 = parseFloat(_gemeloActivo.geometria_adn?.volumen_m3) || 0;

    if (flujoDesague <= 0) {
      panel.innerHTML = '<div style="color:#f59e0b;font-size:0.82rem">' +
        '⚠️ Configura el Flujo de desagüe (LPM) en el Expediente Maestro.</div>';
      return;
    }

    const litros = parseFloat((minutos * flujoDesague).toFixed(1));
    const volLitros = volM3 * 1000;
    const fraccion = volLitros > 0 ? (litros / volLitros) : 0;

    let html = `
      <div style="font-size:0.78rem;margin-top:6px;padding:8px;background:rgba(180,147,9,0.08);border-radius:6px">
        <strong style="color:#b45309">🔄 Retrolavado en vivo</strong><br>
        ⏱️ ${minutos.toFixed(1)} min × ${flujoDesague} LPM = <strong>${litros.toLocaleString('es-MX')} L</strong>
        (${(fraccion * 100).toFixed(1)}% del vaso)
      </div>
    `;

    if (window.Chemistry && typeof window.Chemistry.calcularRetrolavado === 'function' && _albercaActivaId) {
      try {
        const res = window.Chemistry.calcularRetrolavado(_albercaActivaId, minutos);
        if (res && !res.error && res.html) html = res.html;
      } catch (e) { /* silenciar */ }
    }

    panel.innerHTML = html;
  }

