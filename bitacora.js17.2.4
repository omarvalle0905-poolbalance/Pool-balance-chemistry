  /**
   * V17.2.0 ADD: umbrales de dosis dinámicos por modo_operativo
   * Resuelve E2 (Bitácora bloquea supercloraciones de choque).
   * @param {Object} poolState - Objeto con { calculado: { cianurico, modo_operativo } }
   * @returns {Object} Umbrales por parámetro.
   * @private
   */
  function _getUmbralesDosisActuales(poolState) {
    const cya = (poolState && poolState.calculado && poolState.calculado.cianurico)
                ? parseFloat(poolState.calculado.cianurico) : 0;
    const modo = (poolState && poolState.calculado && poolState.calculado.modo_operativo)
                 ? poolState.calculado.modo_operativo : 'rutinario';

    const umbCl = (window.Chemistry && Chemistry.getUmbralesClorOperativos)
                  ? Chemistry.getUmbralesClorOperativos(cya)
                  : { cl_alto: 5, cl_toxico: 10, cl_superchoque: 20 };

    let deltaClBlock;
    let deltaClWarn;
    switch (modo) {
      case 'rutinario':
      case 'recuperacion_leve':
        deltaClWarn  = umbCl.cl_alto;
        deltaClBlock = umbCl.cl_toxico;
        break;
      case 'recuperacion_severa':
        deltaClWarn  = umbCl.cl_toxico;
        deltaClBlock = umbCl.cl_superchoque;
        break;
      case 'rescate':
      case 'post_choque':
        deltaClWarn  = umbCl.cl_superchoque;
        deltaClBlock = umbCl.cl_superchoque * 1.5;
        break;
      case 'metales':
        // V17.2.0: HARD-STOP. Cualquier cloración positiva es BLOCK.
        deltaClWarn  = 0.01;
        deltaClBlock = 0.01;
        break;
      case 'sarro_controlado':
      case 'balance':
      default:
        deltaClWarn  = umbCl.cl_alto;
        deltaClBlock = umbCl.cl_toxico;
    }

    return {
      modo: modo,
      cya: cya,
      deltaCl:  { warn: deltaClWarn, block: deltaClBlock },
      deltaPh:  { warn: 0.5,  block: 1.0  },
      deltaAlk: { warn: 40,   block: 80   },
      deltaCh:  { warn: 100,  block: 200  },
      deltaCya: { warn: 30,   block: 60   }
    };
  }

  // ────────────────────────────────────────────────
  //  V16.7.0 ADD — VISTA PREVIA DE IMPACTO QUÍMICO
