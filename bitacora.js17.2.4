  /**
   * V17.2.0 ADD: ancla diagnóstico V17.2 sec 9.
   * V17.2.1 FIX: elimina llamada duplicada a Engine.recalcularTrasEvento.
   * V17.2.3 FIX BUG-007: emite 'bitacora:diagnostico_anclado' con payload
   *   completo (poolId, parametros, salud) y fuerza
   *   Engine.proyectarEstadoActual(poolId) tras el dispatch.
   * @private
   */
  function _anclarDiagnostico() {
    const poolId = _albercaActivaId;
    if (!poolId) {
      _toast('⚠️ Selecciona una alberca primero.', 'warn');
      return;
    }

    // 1. Recoger Bloque 3 — Salud del Agua
    const claridad = document.getElementById('bit-claridad')
                     ? parseInt(document.getElementById('bit-claridad').value, 10) : null;
    const naturalezaColor = (document.querySelector('input[name="bit-naturaleza-color"]:checked'))
                            ? document.querySelector('input[name="bit-naturaleza-color"]:checked').value : 'ninguna';

    // tipo_alga: si el campo #bit-tipo-alga-presunta no está visible, usar 'ninguna'
    const elTipoAlga = document.getElementById('bit-tipo-alga-presunta');
    const tipoAlgaVisible = elTipoAlga && elTipoAlga.closest('[style*="display: none"]') === null
                            && elTipoAlga.closest('[style*="display:none"]') === null;
    const tipoAlga = (elTipoAlga && tipoAlgaVisible) ? (elTipoAlga.value || 'ninguna') : 'ninguna';

    const visibilidadFondo = document.getElementById('bit-visibilidad-fondo')
                             ? parseFloat(document.getElementById('bit-visibilidad-fondo').value) : null;
    const profundidadVisible = document.getElementById('bit-profundidad-visible')
                               ? parseFloat(document.getElementById('bit-profundidad-visible').value) : null;
    const olor = document.getElementById('bit-olor')
                 ? document.getElementById('bit-olor').value : 'ninguno';

    const saludAgua = {
      claridad_actual: claridad,
      naturaleza_color: naturalezaColor,
      tipo_alga: tipoAlga,
      visibilidad_fondo_m: isNaN(visibilidadFondo) ? null : visibilidadFondo,
      profundidad_visible_m: isNaN(profundidadVisible) ? null : profundidadVisible,
      olor: olor,
      fecha_lectura: new Date().toISOString()
    };

    // 2. Recoger Bloque 4 — ColorQ medido
    const camposColorQ = ['ph','temperatura','cloro_libre','cloro_total',
                          'alcalinidad','dureza_calcica','cianurico','tds'];
    const lecturaColorQ = {};
    const camposMedidos = [];

    camposColorQ.forEach(function(campo) {
      const id = 'bit-colorq-' + campo;
      const input = document.getElementById(id);
      if (!input) return;
      const valor = parseFloat(input.value);
      if (input.classList.contains('colorq-prellenado')) {
        lecturaColorQ[campo] = isNaN(valor) ? null : valor;
      } else {
        lecturaColorQ[campo] = isNaN(valor) ? null : valor;
        if (!isNaN(valor)) camposMedidos.push(campo);
      }
    });
    lecturaColorQ.campos_medidos = camposMedidos;

    // 3. Recoger Bloque 5 — Estado Hidráulico
    const estadoHidraulico = {
      psi_llegada: document.getElementById('bit-psi-llegada')
                   ? (parseFloat(document.getElementById('bit-psi-llegada').value) || null)
                   : null,
      nivel_vaso: document.getElementById('bit-nivel-vaso')
                  ? document.getElementById('bit-nivel-vaso').value : 'normal',
      observacion_bomba: document.getElementById('bit-obs-bomba')
                         ? document.getElementById('bit-obs-bomba').value : '',
      observacion_filtro: document.getElementById('bit-obs-filtro')
                          ? document.getElementById('bit-obs-filtro').value : ''
    };

    // 4. Recoger Bloque 6 — Agua de Llenado (opcional)
    let aguaLlenado = null;
    const fuente = document.getElementById('bit-fuente-agua');
    if (fuente && fuente.value) {
      aguaLlenado = {
        fuente: fuente.value,
        ph: parseFloat(document.getElementById('bit-llenado-ph')?.value) || null,
        alcalinidad: parseFloat(document.getElementById('bit-llenado-alk')?.value) || null,
        dureza: parseFloat(document.getElementById('bit-llenado-dureza')?.value) || null,
        cianurico: parseFloat(document.getElementById('bit-llenado-cya')?.value) || null,
        tds: parseFloat(document.getElementById('bit-llenado-tds')?.value) || null,
        temperatura: parseFloat(document.getElementById('bit-llenado-temp')?.value) || null
      };
    }

    // 5. Recoger tipo_servicio
    const tipoServicio = document.getElementById('bit-tipo')
                         ? document.getElementById('bit-tipo').value : '';

    // 6. Persistir parámetros medidos vía DB.saveRegistro
    if (camposMedidos.length > 0 && window.DB && DB.saveRegistro) {
      const parametrosMedidos = {};
      camposMedidos.forEach(function(c) { parametrosMedidos[c] = lecturaColorQ[c]; });
      try { DB.saveRegistro(poolId, parametrosMedidos); }
      catch (e) { console.warn('[Bitacora._anclarDiagnostico] Error en saveRegistro:', e); }
    }

    // ── V17.2.3 FIX BUG-007: construir parametros (solo campos con valor no vacío) ──
    const parametrosAncla = {};
    const camposParam = ['ph', 'cloro_libre', 'alcalinidad', 'dureza_calcica',
                         'cianurico', 'tds', 'temperatura'];
    camposParam.forEach(function(campo) {
      const idBit = 'bit-' + (campo === 'dureza_calcica' ? 'dureza'
                             : campo === 'cloro_libre'    ? 'cloro-libre'
                             : campo);
      const el = document.getElementById(idBit);
      if (!el) return;
      const v = parseFloat(el.value);
      if (!isNaN(v) && el.value.trim() !== '') parametrosAncla[campo] = v;
    });

    // 7. Disparar evento 'bitacora:diagnostico_anclado' — V17.2.3 FIX BUG-007
    //    Payload completo con poolId, parametros y salud.
    EventBus.dispatch('bitacora:diagnostico_anclado', {
      poolId: poolId,

      // Parámetros medidos (solo campos con valor no vacío)
      parametros: parametrosAncla,

      // Salud visual completa
      salud: {
        claridad: claridad,
        naturaleza_color: naturalezaColor,
        tipo_alga: tipoAlga,
        olor: olor,
        visibilidad_fondo: isNaN(visibilidadFondo) ? null : visibilidadFondo,
        profundidad_visible: isNaN(profundidadVisible) ? null : profundidadVisible
      },

      // Campos adicionales que el engine también consume
      tipo_servicio: tipoServicio,
      tipo_alga: tipoAlga,
      salud_agua: saludAgua,
      lectura_colorq: lecturaColorQ,
      estado_hidraulico: estadoHidraulico,
      agua_llenado: aguaLlenado
    });

    // ── V17.2.3 FIX BUG-007: forzar recálculo inmediato tras el dispatch ──
    if (window.Engine && typeof window.Engine.proyectarEstadoActual === 'function') {
      try { window.Engine.proyectarEstadoActual(poolId); } catch(e) {}
    }

    // 8. Actualizar Isaías (si está disponible)
    if (window.Isaias && Isaias.actualizarClaridadDesdeBitacora) {
      try { Isaias.actualizarClaridadDesdeBitacora(poolId, saludAgua); }
      catch (e) { console.warn('[Bitacora._anclarDiagnostico] Error en Isaias.actualizar:', e); }
    }

    // 9. Toast de éxito con modo activo (con pequeño delay para que engine procese)
    setTimeout(() => {
      const poolState = (window.DB && DB.getPoolState) ? DB.getPoolState(poolId) : null;
      const modoActivo = (poolState && poolState.calculado && poolState.calculado.modo_operativo)
                         ? poolState.calculado.modo_operativo : 'rutinario';
      _toast('✅ Diagnóstico anclado. Modo: ' + modoActivo, 'ok');
    }, 300);

    // 10. Refrescar preview de impacto con nuevos umbrales
    _recalcularTodosLosPreviews();

    window.__bitacoraUltimoAncla = new Date().toISOString();
  }

