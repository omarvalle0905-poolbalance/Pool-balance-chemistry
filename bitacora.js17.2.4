  function _actualizarReporteLlenadoVivo() {
    const panel = $('llenado-live-report');
    if (!panel) return;

    const litros = _numVal('bit-litros-llenado', 0);
    if (litros <= 0 || !_gemeloActivo) { panel.innerHTML = ''; return; }

    const volM3 = parseFloat(_gemeloActivo.geometria_adn?.volumen_m3) || 0;
    const volLitros = volM3 * 1000;
    const fraccion = volLitros > 0 ? (litros / volLitros * 100).toFixed(1) : '?';

    panel.innerHTML = `
      <div style="font-size:0.78rem;padding:8px;background:rgba(59,130,246,0.08);border-radius:6px;margin-top:6px">
        <strong style="color:#3b82f6">💧 Llenado</strong><br>
        ${litros.toLocaleString('es-MX')} L añadidos (${fraccion}% del vaso).
        El motor recalculará la dilución al guardar.
      </div>
    `;
  }

