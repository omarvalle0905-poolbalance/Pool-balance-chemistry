  function _detenerCronoLlenado() {
    if (!_cronometroLlenadoActivo) return;

    if (!_llenadoDetenerPrimerClic) {
      _llenadoDetenerPrimerClic = true;
      const btnDetener = $('btn-detener-llenado');
