    const litros = minutos * flujoLlenado;

    const campoLitros = $('bit-litros-llenado');
    if (campoLitros) campoLitros.value = litros.toFixed(0);

    _actualizarReporteLlenadoVivo();
    _toast(`Llenado: ${litros.toFixed(0)} litros en ${_formatCrono(_cronometroLlenadoSegundos)}`, 'success');
