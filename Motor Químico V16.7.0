  },
  {
    id: 'T_PROJ_02',
    descripcion: 'Cascada eleva pH hasta cruzar zona incrustante.',
    input: {
      estadoInicial: { pH: 7.80, ALK: 110, CH: 350, CYA: 30, TDS: 1200, FC: 2.0, temperatura: 28, recubrimiento: 'porcelanato', profundidad: 1.5, regimen_aireacion: 'cascada', volumen_m3: 50 },
      horizonte_h: 48, eventos: []
    },
    esperado: (r) => r.alerta_salida && r.alerta_salida.lado === 'incrustante'
  },
  {
    id: 'T_PROJ_03',
    descripcion: 'Dosis de bisulfato a h=12 evita cruce de zona.',
    input: {
      estadoInicial: { pH: 7.80, ALK: 110, CH: 350, CYA: 30, TDS: 1200, FC: 2.0, temperatura: 28, recubrimiento: 'porcelanato', profundidad: 1.5, regimen_aireacion: 'cascada', volumen_m3: 50 },
      horizonte_h: 48, eventos: [{ tipo: 'dosis_bisulfato_klaren', hora: 12, cantidad_g: 1500 }]
    },
    esperado: (r, baseline) => !r.alerta_salida || (baseline && baseline.alerta_salida && r.alerta_salida && r.alerta_salida.hora > baseline.alerta_salida.hora)
  },
  {
    id: 'T_PROJ_04',
    descripcion: 'Aún con cascada 168 h, pH se asintota debajo de 8.5.',
    input: {
      estadoInicial: { pH: 7.90, ALK: 120, CH: 350, CYA: 30, TDS: 1200, FC: 2.0, temperatura: 28, recubrimiento: 'porcelanato', profundidad: 1.5, regimen_aireacion: 'cascada', volumen_m3: 50 },
      horizonte_h: 168, eventos: []
    },
    esperado: (r) => r.curva[r.curva.length - 1].pH < 8.5
  },
  {
    id: 'T_PROJ_05',
    descripcion: 'Recubrimiento fibra es más estricto que pebble.',
    input: {
      estadoInicial: { pH: 7.60, ALK: 100, CH: 320, CYA: 30, TDS: 1200, FC: 2.0, temperatura: 28, recubrimiento: 'fibra', profundidad: 1.5, regimen_aireacion: 'filtracion', volumen_m3: 50 },
      horizonte_h: 72, eventos: []
    },
    esperado: (r) => r.zona_recubrimiento.max === 0.10
  },
  {
    id: 'T_PROJ_06',
    descripcion: 'Curva tiene horizonte_h+1 puntos y campos completos.',
    input: {
      estadoInicial: { pH: 7.40, ALK: 100, CH: 300, CYA: 40, TDS: 1200, FC: 2.0, temperatura: 28, recubrimiento: 'porcelanato', profundidad: 1.5, regimen_aireacion: 'filtracion', volumen_m3: 50 },
      horizonte_h: 24, eventos: []
    },
    esperado: (r) => r.curva.length === 25 && typeof r.curva[12].pH === 'number' && typeof r.curva[12].ispb === 'number' && typeof r.curva[12].ALK === 'number'
  }
];

function ejecutarTestsProyector() {
  const resultados = [];
  let pasados = 0, fallados = 0;
  let baseline = null;
  try {
    const tBase = TESTS_PROYECTOR_V17_8.find(t => t.id === 'T_PROJ_02');
    if (tBase) {
      baseline = Chemistry.proyectarISPB(tBase.input.estadoInicial, tBase.input.horizonte_h, tBase.input.eventos);
    }
  } catch (e) { /* noop */ }

  for (const t of TESTS_PROYECTOR_V17_8) {
    try {
      const r = Chemistry.proyectarISPB(t.input.estadoInicial, t.input.horizonte_h, t.input.eventos);
      const ok = !!t.esperado(r, baseline);
      resultados.push({ id: t.id, descripcion: t.descripcion, pasado: ok });
      if (ok) pasados++; else fallados++;
    } catch (e) {
      resultados.push({ id: t.id, descripcion: t.descripcion, pasado: false, error: e.message });
      fallados++;
    }
  }

  const reporte = {
    total: TESTS_PROYECTOR_V17_8.length,
    pasados: pasados,
    fallados: fallados,
    veredicto: (fallados === 0) ? '✅ 6/6 VERDE — Proyector listo' : '❌ Hay tests fallando — Proyector',
    detalle: resultados
  };
  console.log('[Proyector v16.7.0] Tests:', reporte.veredicto);
  return reporte;
}

Chemistry.ejecutarTestsProyector = ejecutarTestsProyector;

