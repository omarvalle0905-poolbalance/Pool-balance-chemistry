function ejecutarTestsDeltaPh() {
  const reporte = { total: TESTS_DELTAPH_V17_8.length, pass: 0, fail: 0, detalles: [] };

  for (const t of TESTS_DELTAPH_V17_8) {
    const detalle = { nombre: t.nombre, pass: false, observaciones: [] };

    if (t.esperado.lanzaError === true) {
      try {
        Chemistry.calcDeltaPhPorDosificacion(t.input.producto, t.input.gramos, t.input.V_m3, t.input.lecturas, t.input.opciones);
        detalle.observaciones.push('Esperaba error, no se lanzó');
      } catch (e) {
        detalle.pass = true;
        detalle.observaciones.push('Error correctamente lanzado: ' + e.message);
      }
      reporte[detalle.pass ? 'pass' : 'fail']++;
      reporte.detalles.push(detalle);
      continue;
    }

    let resultado;
    try {
      resultado = Chemistry.calcDeltaPhPorDosificacion(t.input.producto, t.input.gramos, t.input.V_m3, t.input.lecturas, t.input.opciones);
    } catch (e) {
      detalle.observaciones.push('Error inesperado: ' + e.message);
      reporte.fail++;
      reporte.detalles.push(detalle);
      continue;
    }

    let passLocal = true;
    const E = t.esperado;

    const camposNumericos = ['deltaPhBase', 'nu'];
    for (const campo of camposNumericos) {
      if (E[campo] && typeof E[campo].valor === 'number') {
        const diff = Math.abs(resultado[campo] - E[campo].valor);
        if (diff > E[campo].tolerancia) {
          passLocal = false;
          detalle.observaciones.push(campo + ' fuera de tolerancia: obtenido=' + resultado[campo] + ' esperado=' + E[campo].valor + ' (±' + E[campo].tolerancia + ')');
        }
      }
    }

    if (E.regimen && resultado.regimen !== E.regimen) {
      passLocal = false;
      detalle.observaciones.push('régimen incorrecto: obtenido=' + resultado.regimen + ' esperado=' + E.regimen);
    }

    if (E.premedicacion) {
      if (E.premedicacion.requerida !== undefined && resultado.premedicacion.requerida !== E.premedicacion.requerida) {
        passLocal = false;
        detalle.observaciones.push('premedicacion.requerida incorrecta');
      }
      if (E.premedicacion.producto && resultado.premedicacion.producto !== E.premedicacion.producto) {
        passLocal = false;
        detalle.observaciones.push('premedicacion.producto incorrecto');
      }
    }

    if (E.advertencias_min && resultado.advertencias.length < E.advertencias_min) {
      passLocal = false;
      detalle.observaciones.push('advertencias insuficientes');
    }

    if (E.gaussiana_presente && !resultado.gaussiana) {
      passLocal = false;
      detalle.observaciones.push('gaussiana ausente, se esperaba presente');
    }

    if (E.gaussiana_sigma_max !== undefined && resultado.gaussiana && resultado.gaussiana.sigma > E.gaussiana_sigma_max) {
      passLocal = false;
      detalle.observaciones.push('gaussiana.sigma excede máximo');
    }

    detalle.pass = passLocal;
    detalle.resultado = resultado;
    reporte[passLocal ? 'pass' : 'fail']++;
    reporte.detalles.push(detalle);
  }

  reporte.tasa_exito = (reporte.pass / reporte.total * 100).toFixed(1) + '%';
  console.log('[Solver Completo v16.7.0] Tests:', (reporte.fail === 0) ? '✅ ' + reporte.tasa_exito + ' VERDE' : '❌ Fallos detectados');
  return reporte;
}

Chemistry.ejecutarTestsDeltaPh = ejecutarTestsDeltaPh;

// ═══════════════════════════════════════════════
//  EXPOSICIÓN GLOBAL Y EXPORTS
// ═══════════════════════════════════════════════

window.Chemistry = Chemistry;
window.AuditoriaMasa = AuditoriaMasa;

if (typeof module !== 'undefined' && module.exports) {
  module.exports = Chemistry;
  module.exports.proyectarISPB = Chemistry.proyectarISPB.bind(Chemistry);
  module.exports.calcDeltaPhPorDosificacion = Chemistry.calcDeltaPhPorDosificacion.bind(Chemistry);
  module.exports.TESTS_PROYECTOR_V17_8 = TESTS_PROYECTOR_V17_8;
  module.exports.ejecutarTestsProyector = ejecutarTestsProyector;
  module.exports.TESTS_DELTAPH_V17_8 = TESTS_DELTAPH_V17_8;
  module.exports.ejecutarTestsDeltaPh = ejecutarTestsDeltaPh;
}

// ═══════════════════════════════════════════════
//  BOOT ASSERT — V16.7.0
//  Verifica constantes críticas + Wojtowicz + Proyector + Solver F Oficial
// ═══════════════════════════════════════════════

(function _bootAssert() {
  const C = Chemistry.CONST;
  const requeridas = [
    'TRICLORO_CLORO_PCT', 'TRICLORO_CIAN_PCT', 'HIPO_CALCIO_CLORO_PCT', 'HIPO_CALCIO_DUREZA_PPM_G',
    'CLORO_LIQUIDO_PCT', 'NAOCL_DELTA_ALK_POR_PPM_CL', 'ALCALOS_G_POR_PUNTO_PH_10M3', 'ALKALIN_G_POR_10PPM_10M3',
    'ACIDO_L_POR_PUNTO_PH_10M3', 'HCL_PPM_ALK_POR_LITRO_10M3', 'PH_MENOS_G_BASE_POR_01PH_10M3', 'NAHSO4_G_POR_PPM_ALK_10M3',
    'NAHCO3_G_POR_PPM_ALK_10M3', 'CYA_G_POR_PPM_M3', 'CALCIO_G_POR_10PPM_10M3', 'MAGNESIO_G_POR_PUNTO_PH_10M3',
    'CYA_BLOQUEO', 'PH_OPTIMO_MIN', 'ALK_OPTIMO_MIN', 'CH_OPTIMO_MIN', 'FC_CYA_MIN_PCT', 'FC_CYA_OBJ_PCT',
    'FC_CYA_ALTO_PCT', 'FC_CYA_TOXICO_PCT', 'FC_CYA_SUPERCHOQUE_PCT', 'FC_PISO_ABSOLUTO', 'WOJTOWICZ_TABLA',
    'DESGASIFICACION_VEL_BASE', 'PROYECTOR_COEF_DOSIS', 
    // Constantes del F Completo
    'PKA1_CYA_25C', 'PKA1_H2CO3_DTDT', 'M_TCCA', 'M_NaHCO3', 'PUREZA_TRICLORO', 'ETA_NAOH_MAX', 'NEWTON_SEMILLA_PH',
    'PREMED_FACTOR_SEGURIDAD', 'SIGMA_ALK_PPM', 'ENABLE_DELTAPH_PREDICTION'
  ];

  const faltantes = requeridas.filter(k => typeof C[k] === 'undefined');
  if (faltantes.length > 0) {
    console.error('[Chemistry V' + Chemistry.VERSION + '] Boot assert FAIL: constantes faltantes:', faltantes);
  } else {
    if (C.NAHSO4_G_POR_PPM_ALK_10M3 < 40 || C.NAHSO4_G_POR_PPM_ALK_10M3 > 60) {
      console.warn('[Chemistry V' + Chemistry.VERSION + '] NAHSO4_G_POR_PPM_ALK_10M3 = ' + C.NAHSO4_G_POR_PPM_ALK_10M3 + '. Esperado ~50.94.');
    }
    const ordenFcCya = (
      C.FC_CYA_MIN_PCT < C.FC_CYA_OBJ_PCT &&
      C.FC_CYA_OBJ_PCT < C.FC_CYA_ALTO_PCT &&
      C.FC_CYA_ALTO_PCT < C.FC_CYA_TOXICO_PCT &&
      C.FC_CYA_TOXICO_PCT < C.FC_CYA_SUPERCHOQUE_PCT
    );
    if (!ordenFcCya) {
      console.error('[Chemistry V' + Chemistry.VERSION + '] Boot assert FAIL: orden ordinal de FC/CYA incorrecto.');
    }

    const factores = C.FACTORES_CLORO_POR_MODO;
    const topes = C.TOPES_SALUD_POR_MODO;
    const modosEsperados = ['rutinario','rescate','post_choque','recuperacion_severa','recuperacion_leve','sarro_controlado','balance','metales'];
    const okFactores = modosEsperados.every(m => factores[m] !== undefined);
    const okTopes = modosEsperados.every(m => typeof topes[m] === 'number');

    const umbTest = Chemistry.getUmbralesClorOperativos(57, 'balance');
    const fixUnidadesOK = umbTest && umbTest.cl_minimo > 1 && umbTest.cl_minimo < 10;

    const hoclMethodsOK = (
      typeof Chemistry.calcFraccionHOCl === 'function' &&
      typeof Chemistry.calcHOClActivo === 'function'
    );
    const fTest = hoclMethodsOK ? Chemistry.calcFraccionHOCl(7.5, 25) : null;
    const hoclSanidad = (typeof fTest === 'number' && fTest > 0.3 && fTest < 0.6);

    const wojtowiczOK = (
      typeof Chemistry._factorWojtowicz === 'function' &&
      Array.isArray(C.WOJTOWICZ_TABLA) &&
      C.WOJTOWICZ_TABLA.length === 8 &&
      typeof Chemistry._techoSuavizadoDesgasificacion === 'function' &&
      typeof Chemistry._aplicarEventoProyector === 'function' &&
      typeof Chemistry.proyectarISPB === 'function'
    );

    const solverOK = (
      typeof Chemistry.calcDeltaPhPorDosificacion === 'function' &&
      typeof Chemistry._calcBeta === 'function' &&
      typeof Chemistry._calcularNu === 'function' &&
      typeof Chemistry._resolverCuartica === 'function' &&
      typeof Chemistry._evaluarPremedicacion === 'function' &&
      typeof Chemistry._propagacionGaussiana === 'function'
    );

    if (!okFactores || !okTopes) {
      console.error('[Chemistry V' + Chemistry.VERSION + '] Boot assert FAIL: tablas FACTORES_CLORO_POR_MODO o TOPES_SALUD_POR_MODO incompletas.');
    } else if (!fixUnidadesOK) {
      console.error('[Chemistry V' + Chemistry.VERSION + '] Boot assert FAIL: V16.5.4 fix de unidades FC/CYA no surtió efecto.');
    } else if (!hoclMethodsOK || !hoclSanidad) {
      console.error('[Chemistry V' + Chemistry.VERSION + '] Boot assert FAIL: helpers HOCl ausentes o fuera de rango.');
    } else if (!wojtowiczOK) {
      console.error('[Chemistry V' + Chemistry.VERSION + '] Boot assert FAIL: Paso 1 Wojtowicz o Proyector ausentes.');
    } else if (!solverOK) {
      console.error('[Chemistry V' + Chemistry.VERSION + '] Boot assert FAIL: Entregable F Completo (Premedicación, Gaussiana) ausente.');
    } else {
      console.log('[Chemistry V' + Chemistry.VERSION + '] Boot assert OK: Todas las constantes, fix V16.5.4, helpers HOCl, Wojtowicz, Proyector y Entregable F (Full Doctrina) cargados. V16.7.0 Ciber-Físico Activo.');
    }
  }
})();

console.log('[Chemistry] Motor Quimico V' + Chemistry.VERSION + ' — ISPB Langelier NSPF (12.1). Factor Omar. Regla Suprema de Cloracion. CPO-verified. Klaren calibrado. + Regla FC/CYA dinámica + modos operativos + Alkalin colateral pH + Alcalos hard-stop + helpers HOCl (Pankow) + Wojtowicz dinámico + Proyector Temporal ISPB + Solver Cuártico de Dosis (FULL DOCTRINA). V16.7.0 Activo. | ' + Chemistry.CONST.FIRMA);
